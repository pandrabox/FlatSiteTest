---
// src/pages/guide/index.astro
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const currentBase = import.meta.env.BASE_URL + '/';

// Get all guides and sort by stepNumber
const allGuides = await getCollection('guides');
const sortedGuides = allGuides.sort((a, b) => a.data.stepNumber - b.data.stepNumber);

const SEO_TITLE = "VRChatケモノ初心者入門ガイド | VRで始めるもふもふライフの歩き方";
const SEO_DESCRIPTION = "「VRChatでケモノになってみたい！」そんな初心者の夢を叶える9つのステップ。アバター選び、無料試着、コミュニティ交流、Booth購入、Unityアップロード、着せ替え改変、クロスプラットフォーム対応まで徹底解説！";
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <BaseHead title={SEO_TITLE} description={SEO_DESCRIPTION} />
    <style>
      .guide-header {
        text-align: center;
        background: linear-gradient(135deg, hsl(37, 95%, 72%) 0%, hsl(30, 85%, 45%) 100%);
        color: var(--color-text-white);
        padding: 5rem 1.5rem;
        border-radius: 0 0 var(--radius-lg) var(--radius-lg);
      }

      .guide-header h1 {
        font-size: clamp(2rem, 5vw, 3.2rem);
        color: var(--color-text-white);
        margin-bottom: 1rem;
        font-weight: 900;
        text-shadow: 0 4px 10px rgba(0,0,0,0.1);
      }

      .guide-header p {
        font-size: clamp(0.95rem, 2vw, 1.15rem);
        color: rgba(255, 255, 255, 0.9);
        max-width: 700px;
        margin: 0 auto;
        line-height: 1.6;
      }

      .guide-container {
        max-width: 900px;
        margin: 4rem auto;
        padding: 0 1.5rem;
        position: relative;
      }

      /* 縦のタイムライン軸線 */
      .timeline-track {
        position: absolute;
        top: 0;
        bottom: 0;
        left: 40px;
        width: 4px;
        background: linear-gradient(to bottom, var(--color-brand) 0%, var(--color-brand-light) 70%, rgba(244, 173, 57, 0.1) 100%);
        border-radius: 2px;
        z-index: 1;
      }

      .step-item {
        position: relative;
        z-index: 2;
        margin-bottom: 2.5rem;
        padding-left: 80px;
        display: flex;
        flex-direction: column;
      }

      .step-item:last-child {
        margin-bottom: 0;
      }

      .step-badge {
        position: absolute;
        left: 12px;
        top: 0;
        width: 60px;
        height: 60px;
        background: var(--color-brand);
        color: var(--color-text-white);
        border-radius: 50%;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        font-family: 'Fredoka', sans-serif;
        box-shadow: 0 8px 20px rgba(244, 173, 57, 0.35);
        border: 4px solid var(--color-bg);
        transition: var(--transition-smooth);
      }

      .step-badge-num {
        font-size: 1.4rem;
        font-weight: 800;
        line-height: 1;
      }

      .step-badge-label {
        font-size: 0.55rem;
        font-weight: 700;
        letter-spacing: 0.05em;
      }

      .step-item:hover .step-badge {
        transform: scale(1.1) rotate(15deg);
        background: var(--color-accent);
        box-shadow: 0 8px 20px rgba(231, 76, 60, 0.35);
      }

      .step-card {
        background: var(--color-bg-glass);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-lg);
        padding: 1.5rem;
        box-shadow: var(--shadow-glass);
        transition: var(--transition-smooth);
        display: block;
        text-decoration: none !important;
        color: inherit;
      }

      .step-card,
      .step-card * {
        text-decoration: none !important;
      }

      .step-card:hover {
        transform: translateY(-4px);
        box-shadow: var(--shadow-medium);
        border-color: var(--color-brand);
      }

      .step-card:hover h2 {
        color: var(--color-brand-dark);
      }

      .step-card:hover .card-arrow {
        transform: translateX(6px);
      }

      .step-card h2 {
        font-size: 1.3rem;
        font-weight: 800;
        color: var(--color-text);
        margin-bottom: 0.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 8px;
        transition: var(--transition-fast);
      }

      .card-arrow {
        font-size: 1.2rem;
        color: var(--color-brand);
        transition: var(--transition-smooth);
      }

      .step-card p {
        color: var(--color-text-muted);
        font-size: 0.95rem;
        line-height: 1.6;
        margin-bottom: 0;
      }

      .step-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        margin-top: 0.35rem;
        line-height: 1.2;
      }

      .keyword-tag {
        color: var(--color-text-muted);
        font-size: 0.7rem;
        opacity: 0.55;
        transition: var(--transition-fast);
      }

      .keyword-tag:hover {
        opacity: 0.85;
      }

      .keyword-tag:not(:last-child)::after {
        content: "•";
        margin-left: 6px;
        color: var(--color-text-muted);
        opacity: 0.4;
      }

      @media (max-width: 600px) {
        .timeline-track {
          left: 20px;
        }

        .step-item {
          padding-left: 50px;
          margin-bottom: 2rem;
        }

        .step-badge {
          width: 44px;
          height: 44px;
          left: -2px;
        }

        .step-badge-num {
          font-size: 1.1rem;
        }

        .step-badge-label {
          display: none;
        }

        .step-card {
          padding: 1rem;
        }

        .step-card h2 {
          font-size: 1.15rem;
        }
      }
    </style>
  </head>
  <body>
    <Header />

    <!-- ページヘッダー -->
    <header class="guide-header">
      <h1>VRChatケモノ初心者入門ガイド</h1>
      <p>「VRでケモノになって、もふもふに囲まれて暮らしたい！」<br/>フラットくんに興味を持ったあなたの夢を、アバターの選び方からカスタム、クロスプラットフォーム対応まで全9つのステップで丁寧にサポートします。</p>
    </header>

    <!-- ガイド一覧 (タイムライン形式) -->
    <main class="guide-container">
      <div class="timeline-track"></div>

      {sortedGuides.map((guide) => (
        <article class="step-item">
          <div class="step-badge">
            <span class="step-badge-num">{guide.data.stepNumber}</span>
            <span class="step-badge-label">STEP</span>
          </div>

          <a href={`${currentBase}guide/${guide.id}/`} class="step-card">
            <h2>
              <span>🐾 {guide.data.title}</span>
              <span class="card-arrow">→</span>
            </h2>
            <p>{guide.data.description}</p>

            {guide.data.keywords && (
              <div class="step-meta">
                {guide.data.keywords.map((kw) => (
                  <span class="keyword-tag">#{kw}</span>
                ))}
              </div>
            )}
          </a>
        </article>
      ))}
    </main>

    <Footer />
  </body>
</html>
