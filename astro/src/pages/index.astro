---
// src/pages/index.astro
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

const currentBase = import.meta.env.BASE_URL;

const clothImages = [
  "FCamera_20260531_131016.webp",
  "FCamera_20260531_131144.webp",
  "FCamera_20260531_131307.webp",
  "FCamera_20260531_131426.webp",
  "FCamera_20260531_131536.webp",
  "FCamera_20260531_131619.webp",
  "FCamera_20260531_131653.webp",
  "FCamera_20260531_131815.webp",
  "FCamera_20260531_132540.webp",
  "FCamera_20260531_132638.webp",
  "FCamera_20260531_132751.webp",
];

// クローン用のデータ抽出 (前後にシームレスに配置するため)
const clonesStart = clothImages.slice(-3); // 最後の3枚
const clonesEnd = clothImages.slice(0, 3); // 最初の3枚
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <BaseHead title={`${SITE_TITLE} | VRではじめる、もふもふケモノライフ`} description={SITE_DESCRIPTION} />
    <style>
      /* ヒーローセクション */
      .hero {
        position: relative;
        height: calc(100vh - 70px);
        min-height: 550px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, hsl(37, 95%, 72%) 0%, hsl(30, 85%, 45%) 100%);
        overflow: hidden;
        color: var(--color-text-white);
        text-align: center;
        padding: 2rem 1.5rem;
      }

      .hero-bg {
        position: absolute;
        top: 0; left: 0; width: 100%; height: 100%;
        z-index: 1;
        opacity: 0.25;
      }

      .hero-bg img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        filter: blur(4px);
      }

      .hero-content {
        position: relative;
        z-index: 2;
        max-width: 800px;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1.5rem;
        animation: fadeInUp 1s cubic-bezier(0.16, 1, 0.3, 1);
      }

      .hero-badge {
        background: rgba(255, 255, 255, 0.2);
        backdrop-filter: blur(10px);
        padding: 6px 18px;
        border-radius: 50px;
        font-weight: 700;
        font-size: 0.9rem;
        letter-spacing: 0.05em;
        border: 1px solid rgba(255, 255, 255, 0.3);
      }

      .hero h1 {
        font-size: clamp(2.2rem, 6vw, 4.2rem);
        color: var(--color-text-white);
        line-height: 1.25;
        text-shadow: 0 4px 15px rgba(0,0,0,0.15);
      }

      .hero p {
        font-size: clamp(1rem, 2vw, 1.25rem);
        color: rgba(255, 255, 255, 0.9);
        max-width: 600px;
        line-height: 1.6;
        text-shadow: 0 2px 8px rgba(0,0,0,0.1);
        word-break: keep-all;
      }

      .hero-actions {
        display: flex;
        gap: 1rem;
        margin-top: 1rem;
      }

      @keyframes fadeInUp {
        from {
          opacity: 0;
          transform: translateY(30px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      /* セクション共通 */
      .section {
        padding: 6rem 1.5rem;
        max-width: 1200px;
        margin: 0 auto;
      }

      .section-header {
        text-align: center;
        max-width: 700px;
        margin: 0 auto 4rem auto;
      }

      .section-header h2 {
        font-size: clamp(1.8rem, 4vw, 2.5rem);
        color: var(--color-text);
        margin-bottom: 1rem;
        position: relative;
        display: inline-block;
      }

      .section-header h2::after {
        content: '🐾';
        position: absolute;
        bottom: -25px;
        left: 50%;
        transform: translateX(-50%);
        font-size: 1.2rem;
      }

      .section-header p {
        color: var(--color-text-muted);
        font-size: 1.05rem;
        margin-top: 1.5rem;
        word-break: keep-all;
      }

      /* アバターバリエーション紹介 */
      .avatar-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 2rem;
      }

      .avatar-card {
        background: var(--color-bg-glass);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-lg);
        overflow: hidden;
        box-shadow: var(--shadow-glass);
        transition: var(--transition-smooth);
        display: flex;
        flex-direction: column;
      }

      .avatar-card:hover {
        transform: translateY(-8px);
        box-shadow: var(--shadow-premium);
        border-color: var(--color-brand);
      }

      .avatar-img-wrapper {
        position: relative;
        aspect-ratio: 1;
        background-color: var(--color-bg-secondary);
        overflow: hidden;
      }

      .avatar-img-wrapper img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: var(--transition-smooth);
      }

      .avatar-card:hover .avatar-img-wrapper img {
        transform: scale(1.05);
      }

      .avatar-badge {
        position: absolute;
        top: 12px;
        right: 12px;
        background: var(--color-brand-dark);
        color: var(--color-text-white);
        font-size: 0.75rem;
        font-weight: 800;
        padding: 4px 10px;
        border-radius: 30px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
      }

      .avatar-info {
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        flex-grow: 1;
        gap: 0.8rem;
      }

      .avatar-info h3 {
        font-size: 1.25rem;
        font-weight: 800;
      }

      .avatar-price {
        font-family: 'Fredoka', sans-serif;
        font-size: 1.35rem;
        font-weight: 700;
        color: var(--color-accent);
      }

      .avatar-desc {
        font-size: 0.9rem;
        color: var(--color-text-muted);
        line-height: 1.5;
      }

      .avatar-rank {
        display: flex;
        gap: 2px;
        color: #FFD700;
        font-size: 0.9rem;
      }

      /* イージング付きシームレス無限カルーセル */
      .carousel-container {
        position: relative;
        width: 100%;
        max-width: 1200px;
        margin: 0 auto;
        padding: 1.5rem 0;
      }

      .carousel-window {
        overflow: hidden;
        width: 100%;
        cursor: grab;
        border-radius: var(--radius-lg);
        padding: 10px 0;
        touch-action: pan-y;
      }

      .carousel-window:active {
        cursor: grabbing;
      }

      .carousel-track {
        display: flex;
        user-select: none;
        will-change: transform;
        transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
      }

      .carousel-slide {
        flex: 0 0 33.333%;
        padding: 0 1rem;
        box-sizing: border-box;
        transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.6s ease;
        opacity: 0.45;
        transform: scale(0.9);
      }

      .carousel-slide.no-transition,
      .carousel-slide.no-transition .carousel-card {
        transition: none !important;
      }

      .carousel-slide.active {
        opacity: 1;
        transform: scale(1.02);
      }

      .carousel-card {
        background: var(--color-bg-glass);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-md);
        overflow: hidden;
        box-shadow: var(--shadow-glass);
        transition: var(--transition-smooth);
        display: flex;
        flex-direction: column;
      }

      .carousel-slide.active .carousel-card {
        box-shadow: var(--shadow-medium);
        border-color: var(--color-brand);
      }

      .carousel-img-container {
        width: 100%;
        height: 480px;
        overflow: hidden;
        background-color: var(--color-bg-secondary);
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: var(--radius-md);
      }

      .carousel-img-container img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        pointer-events: none;
        transition: var(--transition-smooth);
      }

      .carousel-slide.active:hover .carousel-img-container img {
        transform: scale(1.04);
      }

      /* カルーセルコントロール（矢印） */
      .carousel-control {
        position: absolute;
        top: 50%;
        transform: translateY(-50%);
        width: 50px;
        height: 50px;
        border-radius: 50%;
        background: var(--color-bg-glass);
        border: 1px solid var(--color-border);
        color: var(--color-brand-dark);
        display: flex;
        align-items: center;
        justify-content: center;
        cursor: pointer;
        z-index: 10;
        box-shadow: var(--shadow-glass);
        transition: var(--transition-smooth);
        padding: 0;
      }

      .carousel-control:hover {
        background: var(--color-brand);
        color: var(--color-text-white);
        border-color: var(--color-brand);
        box-shadow: var(--shadow-premium);
        transform: translateY(-50%) scale(1.08);
      }

      .carousel-control.prev {
        left: -25px;
      }

      .carousel-control.next {
        right: -25px;
      }

      /* インジケータードット */
      .carousel-dots {
        display: flex;
        justify-content: center;
        gap: 8px;
        margin-top: 2rem;
      }

      .dot {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background: var(--color-bg-secondary);
        border: 1px solid rgba(244, 173, 57, 0.2);
        cursor: pointer;
        transition: var(--transition-smooth);
        padding: 0;
      }

      .dot:hover {
        background: var(--color-brand-light);
      }

      .dot.active {
        width: 24px;
        border-radius: 10px;
        background: var(--color-brand);
        border-color: var(--color-brand);
      }

      /* コミュニティショーケース */
      .community-banner {
        position: relative;
        border-radius: var(--radius-lg);
        overflow: hidden;
        min-height: 420px;
        display: flex;
        align-items: center;
        justify-content: flex-start;
        padding: 3rem;
        box-shadow: var(--shadow-medium);
      }

      .community-banner-bg {
        position: absolute;
        top: 0; left: 0; width: 100%; height: 100%;
        z-index: 1;
      }

      .community-banner-bg img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .community-banner::before {
        content: '';
        position: absolute;
        top: 0; left: 0; width: 100%; height: 100%;
        background: linear-gradient(90deg, rgba(0, 0, 0, 0.6) 0%, rgba(0, 0, 0, 0.2) 100%);
        z-index: 2;
      }

      .community-card {
        position: relative;
        z-index: 3;
        max-width: 480px;
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        padding: 2.5rem;
        border-radius: var(--radius-md);
        box-shadow: 0 20px 40px rgba(0,0,0,0.15);
        border: 1px solid rgba(255, 255, 255, 0.5);
      }

      .community-card h3 {
        font-size: 1.6rem;
        color: var(--color-brand-dark);
        margin-bottom: 1rem;
      }

      .community-card p {
        color: var(--color-text);
        font-size: 0.95rem;
        line-height: 1.6;
        margin-bottom: 1.5rem;
      }

      /* 最後のWelcome CTA */
      .cta-section {
        background: linear-gradient(135deg, hsl(38, 25%, 93%) 0%, hsl(40, 40%, 98%) 100%);
        border-radius: var(--radius-lg);
        text-align: center;
        padding: 5rem 2rem;
        border: 1px solid var(--color-border);
        box-shadow: var(--shadow-glass);
      }

      .cta-section h2 {
        font-size: 2.2rem;
        color: var(--color-brand-dark);
        margin-bottom: 1rem;
      }

      .cta-section p {
        color: var(--color-text-muted);
        max-width: 600px;
        margin: 0 auto 2.5rem auto;
        font-size: 1.05rem;
      }

      /* レスポンシブ */
      @media (max-width: 900px) {
        .carousel-slide {
          flex: 0 0 50%;
        }

        .carousel-control.prev {
          left: 5px;
        }

        .carousel-control.next {
          right: 5px;
        }

        .community-banner {
          padding: 1.5rem;
          justify-content: center;
          min-height: auto;
        }

        .community-card {
          padding: 1.5rem;
          max-width: 100%;
        }

        .hero-actions {
          flex-direction: column;
          width: 100%;
        }

        .hero-actions .btn {
          width: 100%;
        }
      }

      @media (max-width: 600px) {
        .carousel-slide {
          flex: 0 0 100%;
        }

        .carousel-img-container {
          height: 380px;
        }

        .carousel-control {
          display: none; /* タブレット以下はスワイプ対応のため非表示 */
        }
      }
    </style>
  </head>
  <body>
    <Header />

    <!-- 1. ヒーローセクション -->
    <section class="hero">
      <div class="hero-bg">
        <img src={`${currentBase}images/FirstViewPC.webp`} alt="VRChat フラットくんの笑顔が集まる背景画像" />
      </div>
      <div class="hero-content">
        <span class="hero-badge">🐾 非公式フラットファンサイト</span>
        <h1>VRではじめる、<br/>もふもふケモノライフ</h1>
        <p>VRChat向け着ぐるみ体型ケモノアバター「フラット」くんの<wbr>非公式ファンサイトへようこそ！<wbr>アバターの魅力から、<wbr>初心者向けアップロード、<wbr>着替えの方法まで徹底ガイドします。</p>
        <div class="hero-actions">
          <a href={`${currentBase}guide/`} class="btn btn-primary btn-lg">入門ガイドを見る 🐾</a>
          <a href="#gallery" class="btn btn-secondary btn-lg">コーディネートを見る</a>
        </div>
      </div>
    </section>

    <!-- 2. アバター紹介セクション -->
    <section class="section">
      <div class="section-header">
        <h2>アバターバリエーション</h2>
        <p>フラットくんには個性に合わせた4つの公式バリエーションがあります。<br/>あなたの心にピンとくる、お気に入りのフラットくんを見つけよう！</p>
      </div>

      <div class="avatar-grid">
        <!-- 1. 無印 -->
        <article class="avatar-card">
          <div class="avatar-img-wrapper">
            <img src={`${currentBase}images/FlatNormal.webp`} alt="VRC ケモノ フラット 無印バージョン アバター画像" />
            <span class="avatar-badge">基本形</span>
          </div>
          <div class="avatar-info">
            <div class="avatar-rank">⭐⭐⭐⭐★</div>
            <h3>フラット (無印)</h3>
            <span class="avatar-price">¥3,000</span>
            <p class="avatar-desc">服のないプレーンな初期バージョン。シンプルなため、配布されている無数のファンメイド衣装をお得に着せ替えたい方に最適！</p>
          </div>
        </article>

        <!-- 2. 2nd -->
        <article class="avatar-card">
          <div class="avatar-img-wrapper">
            <img src={`${currentBase}images/Flat2nd.webp`} alt="VRC ケモノ フラット 2nd Anniversary パーカーアバター画像" />
            <span class="avatar-badge">カジュアル</span>
          </div>
          <div class="avatar-info">
            <div class="avatar-rank">⭐⭐⭐⭐★</div>
            <h3>Flat 2nd Anniv.</h3>
            <span class="avatar-price">¥3,980</span>
            <p class="avatar-desc">2周年記念のカジュアル専用ジップパーカー付き。購入してすぐに普段着スタイルで可愛くお出かけできます。</p>
          </div>
        </article>

        <!-- 3. 4th -->
        <article class="avatar-card">
          <div class="avatar-img-wrapper">
            <img src={`${currentBase}images/Flat4th.webp`} alt="VRC ケモノ フラット 4th Anniversary アバター画像" />
            <span class="avatar-badge">公式推奨</span>
          </div>
          <div class="avatar-info">
            <div class="avatar-rank">⭐⭐⭐⭐⭐</div>
            <h3>Flat 4th Anniv.</h3>
            <span class="avatar-price">¥3,980</span>
            <p class="avatar-desc">4周年を記念したクールなサイバーパンク風ネオン衣装。沢山の表情、耳の動きに対応した公式推奨アバター。</p>
          </div>
        </article>

        <!-- 4. IF -->
        <article class="avatar-card">
          <div class="avatar-img-wrapper">
            <img src={`${currentBase}images/FlatIF.webp`} alt="VRC ケモノ フラット If Ver アバター画像" />
            <span class="avatar-badge">個性派</span>
          </div>
          <div class="avatar-info">
            <div class="avatar-rank">⭐⭐⭐⭐★</div>
            <h3>Flat If Ver</h3>
            <span class="avatar-price">¥3,980</span>
            <p class="avatar-desc">「もしもフラットくんがやんちゃだったら？」のIFアバター。いつもと違うストリートジャケットが超個性的！</p>
          </div>
        </article>
      </div>
    </section>

    <!-- 3. コーディネートギャラリーカルーセルセクション -->
    <section class="section" id="gallery">
      <div class="section-header">
        <h2>オリジナルコーディネート</h2>
        <p>いろいろな衣装を身にまとったフラットくんたち！<br/>35種類以上ある衣装を簡単に着替えて、こんなに多様で可愛い個性を放ちます。</p>
      </div>

      <div class="carousel-container">
        <!-- カルーセル窓枠 -->
        <div class="carousel-window" id="carouselWindow">
          <div class="carousel-track" id="carouselTrack">
            
            <!-- 【1. 開始側の無限連結用クローン（最後の3枚）】 -->
            {clonesStart.map((imgName, index) => {
              const originalIndex = clothImages.length - 3 + index;
              return (
                <div class="carousel-slide clone-slide" data-index={originalIndex}>
                  <div class="carousel-card">
                    <div class="carousel-img-container">
                      <img 
                        src={`${currentBase}images/ClothSample/${imgName}`} 
                        alt="シームレス無限スライド用のクローン画像" 
                        loading="lazy" 
                      />
                    </div>
                  </div>
                </div>
              );
            })}

            <!-- 【2. 本番の11枚のスライド】 -->
            {clothImages.map((imgName, index) => (
              <div class="carousel-slide real-slide" data-index={index}>
                <div class="carousel-card">
                  <div class="carousel-img-container">
                    <img 
                      src={`${currentBase}images/ClothSample/${imgName}`} 
                      alt={`様々な衣装を着たフラットくんのコーディネート写真 #${index + 1}`} 
                      loading="lazy" 
                    />
                  </div>
                </div>
              </div>
            ))}

            <!-- 【3. 終了側の無限連結用クローン（最初の3枚）】 -->
            {clonesEnd.map((imgName, index) => (
              <div class="carousel-slide clone-slide" data-index={index}>
                <div class="carousel-card">
                  <div class="carousel-img-container">
                    <img 
                      src={`${currentBase}images/ClothSample/${imgName}`} 
                      alt="シームレス無限スライド用のクローン画像" 
                      loading="lazy" 
                    />
                  </div>
                </div>
              </div>
            ))}

          </div>
        </div>

        <!-- 左右コントロールボタン -->
        <button class="carousel-control prev" id="prevBtn" aria-label="前のスライド">
          <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="15 18 9 12 15 6"></polyline>
          </svg>
        </button>
        <button class="carousel-control next" id="nextBtn" aria-label="次のスライド">
          <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="9 18 15 12 9 6"></polyline>
          </svg>
        </button>

        <!-- インジケータードット -->
        <div class="carousel-dots" id="carouselDots">
          {clothImages.map((_, index) => (
            <button class="dot" data-index={index} aria-label={`スライド ${index + 1} へ移動`}></button>
          ))}
        </div>
      </div>
    </section>

    <!-- 4. コミュニティセクション -->
    <section class="section">
      <div class="community-banner">
        <div class="community-banner-bg">
          <img src={`${currentBase}images/Meetup.webp`} alt="100人以上のフラットくんが集結した大迫力の定例集会写真" />
        </div>
        <div class="community-card">
          <h3>あたたかいコミュニティ 💛</h3>
          <p>フラットくんの仲間たちは非常にフレンドリー！年に1度開催される定例集会には100名以上のオーナーが大集合し、お揃いの衣装や改変を持ち寄ってお祝いします。</p>
          <a href={`${currentBase}community/`} class="btn btn-primary">コミュニティの詳細を見る</a>
        </div>
      </div>
    </section>

    <!-- 5. 最後のCTAセクション -->
    <section class="section">
      <div class="cta-section">
        <h2>さあ、もふもふの世界へ会いにいこう</h2>
        <p>VRChatの始め方がわからなくても大丈夫！アバターの選び方から、購入、Unityでのアップロード設定までを、初心者向けに優しく1からガイドします。</p>
        <a href={`${currentBase}guide/`} class="btn btn-accent btn-lg" style="font-size: 1.2rem; padding: 15px 45px;">
          入門ガイドを見る (全7ステップ) 🐾
        </a>
      </div>
    </section>

    <Footer />

    <script>
      // 1. Interactive Closet Logic
      const btnBase = document.getElementById('btnBase');
      const btnClothes1 = document.getElementById('btnClothes1');
      const clothesOverlay1 = document.getElementById('clothesOverlay1');

      if (btnBase && btnClothes1 && clothesOverlay1) {
        btnBase.addEventListener('click', () => {
          btnBase.classList.add('active');
          btnClothes1.classList.remove('active');
          clothesOverlay1.classList.remove('active');
        });

        btnClothes1.addEventListener('click', () => {
          btnClothes1.classList.add('active');
          btnBase.classList.remove('active');
          clothesOverlay1.classList.add('active');
        });
      }

      // 2. 衣装イージング表示 カルーセルロジック
      const tWindowFrame = document.getElementById('carouselWindow');
      const tTrack = document.getElementById('carouselTrack');
      const slides = document.querySelectorAll('.carousel-slide');
      const dots = document.querySelectorAll('.dot');
      const tPrevBtn = document.getElementById('prevBtn');
      const tNextBtn = document.getElementById('nextBtn');

      if (tWindowFrame && tTrack && slides.length > 0) {
        const totalSlides = slides.length;
        const totalRealSlides = totalSlides - 6; // 前後3枚ずつのクローンを除く
        let currentIndex = 3; // 最初の実体スライド (インデックス3) から開始
        let autoplayTimer = null;
        let isHovered = false;

        function startAutoplay() {
          stopAutoplay();
          autoplayTimer = setInterval(() => {
            if (!isHovered && !isDragging) {
              currentIndex++;
              updateSlider(true);
            }
          }, 3500); // 3.5秒ごとに自動スライド
        }

        function stopAutoplay() {
          if (autoplayTimer) {
            clearInterval(autoplayTimer);
            autoplayTimer = null;
          }
        }

        // ホバー監視
        tWindowFrame.addEventListener('mouseenter', () => {
          isHovered = true;
          stopAutoplay();
        });

        tWindowFrame.addEventListener('mouseleave', () => {
          isHovered = false;
          startAutoplay();
        });

        // タッチ端末でのスクロール/タップでの一時停止対応
        tWindowFrame.addEventListener('touchstart', () => {
          isHovered = true;
          stopAutoplay();
        }, { passive: true });

        tWindowFrame.addEventListener('touchend', () => {
          isHovered = false;
          startAutoplay();
        }, { passive: true });


        // 軽量・高精細ドラッグ＆スワイプ制御 (Pointer Events API)
        let startX = 0;
        let isDragging = false;
        let currentTranslate = 0;
        let prevTranslate = 0;

        tWindowFrame.addEventListener('pointerdown', (e) => {
          startX = e.clientX;
          isDragging = true;
          stopAutoplay();
          tTrack.style.transition = 'none'; // ドラッグ中はイージングアニメーションを切る
          slides.forEach(slide => {
            slide.style.transition = 'none'; // ドラッグ中の表情スケール変化を瞬時に追従
          });

          const isMobile = window.innerWidth <= 600;
          const isTablet = window.innerWidth <= 900 && window.innerWidth > 600;
          let cardWidth = 33.333;
          let centerOffset = 33.333;
          if (isMobile) { cardWidth = 100; centerOffset = 0; }
          else if (isTablet) { cardWidth = 50; centerOffset = 25; }

          prevTranslate = -(currentIndex * cardWidth) + centerOffset;
          tWindowFrame.setPointerCapture(e.pointerId);
        });

        tWindowFrame.addEventListener('pointermove', (e) => {
          if (!isDragging) return;
          const currentX = e.clientX;
          const diffX = currentX - startX;

          // ピクセル単位の移動量を、トラックの親コンテナに対するパーセンテージに変換
          const containerWidth = tWindowFrame.clientWidth;
          const diffPercent = (diffX / containerWidth) * 100;

          currentTranslate = prevTranslate + diffPercent;
          tTrack.style.transform = `translateX(${currentTranslate}%)`;
        });

        tWindowFrame.addEventListener('pointerup', (e) => {
          if (!isDragging) return;
          isDragging = false;
          tTrack.style.transition = 'transform 0.6s cubic-bezier(0.16, 1, 0.3, 1)'; // イージングを復元
          slides.forEach(slide => {
            slide.style.transition = ''; // CSSの定義に戻す
          });

          const currentX = e.clientX;
          const diffX = currentX - startX;
          const threshold = 40; // 40px以上のドラッグで隣のスライドへスナップ移動

          if (diffX < -threshold) {
            currentIndex++;
          } else if (diffX > threshold) {
            currentIndex--;
          }

          updateSlider(true);
          tWindowFrame.releasePointerCapture(e.pointerId);
          startAutoplay();
        });

        tWindowFrame.addEventListener('pointercancel', (e) => {
          if (!isDragging) return;
          isDragging = false;
          tTrack.style.transition = 'transform 0.6s cubic-bezier(0.16, 1, 0.3, 1)';
          slides.forEach(slide => {
            slide.style.transition = ''; // CSSの定義に戻す
          });
          updateSlider(true);
          tWindowFrame.releasePointerCapture(e.pointerId);
          startAutoplay();
        });


        function updateSlider(withTransition = true) {
          const isMobile = window.innerWidth <= 600;
          const isTablet = window.innerWidth <= 900 && window.innerWidth > 600;

          let cardWidth = 33.333;
          let centerOffset = 33.333; // 1枚分の幅をずらしてセンターに

          if (isMobile) {
            cardWidth = 100;
            centerOffset = 0;
          } else if (isTablet) {
            cardWidth = 50;
            centerOffset = 25; // 半個分の幅をずらしてセンターに
          }

          if (withTransition) {
            tTrack.style.transition = 'transform 0.6s cubic-bezier(0.16, 1, 0.3, 1)';
            slides.forEach(slide => {
              slide.style.transition = ''; // CSSの定義に戻す
            });
          } else {
            tTrack.style.transition = 'none';
            slides.forEach(slide => {
              slide.style.transition = 'none';
            });
          }

          // イージング付きの移動量計算
          const transformValue = -(currentIndex * cardWidth) + centerOffset;
          tTrack.style.transform = `translateX(${transformValue}%)`;

          // アクティブクラスの更新 (センターのカードを拡大＆高透過率に)
          slides.forEach((slide, index) => {
            if (index === currentIndex) {
              slide.classList.add('active');
            } else {
              slide.classList.remove('active');
            }
          });

          // 無限ループ用にインジケータードットを本番の11個に補正マッピング
          let realIndex = (currentIndex - 3) % totalRealSlides;
          if (realIndex < 0) {
            realIndex += totalRealSlides;
          }

          dots.forEach((dot, index) => {
            if (index === realIndex) {
              dot.classList.add('active');
            } else {
              dot.classList.remove('active');
            }
          });
        }

        // コントロールボタンイベント
        if (tPrevBtn && tNextBtn) {
          tPrevBtn.addEventListener('click', () => {
            currentIndex--;
            updateSlider(true);
          });

          tNextBtn.addEventListener('click', () => {
            currentIndex++;
            updateSlider(true);
          });
        }

        // ドットのクリック (対応する本物のインデックス3〜13へジャンプ)
        dots.forEach((dot, index) => {
          dot.addEventListener('click', () => {
            currentIndex = index + 3;
            updateSlider(true);
          });
        });

        // スライドのクリックでの直接フォーカス
        slides.forEach((slide, index) => {
          slide.addEventListener('click', () => {
            currentIndex = index;
            updateSlider(true);
          });
        });

        // 【シームレス無限ループのためのトランジション終了時テレポート制御】
        tTrack.addEventListener('transitionend', (e) => {
          if (e.propertyName !== 'transform') return;

          const isMobile = window.innerWidth <= 600;
          const isTablet = window.innerWidth <= 900 && window.innerWidth > 600;
          let cardWidth = 33.333;
          let centerOffset = 33.333;

          if (isMobile) {
            cardWidth = 100;
            centerOffset = 0;
          } else if (isTablet) {
            cardWidth = 50;
            centerOffset = 25;
          }

          // 右端のクローンを超えたら本物のスタートへ瞬時テレポート
          if (currentIndex >= totalSlides - 3) {
            currentIndex = 3;
          }
          // 左端のクローンを下回ったら本物のエンドへ瞬時テレポート
          else if (currentIndex < 3) {
            currentIndex = totalSlides - 4;
          }
          else {
            return; // テレポートしない場合は早期リターン
          }

          // テレポート: スライドのトランジションを一時的に無効化してカードが縮むのを防ぐ
          slides.forEach(slide => slide.classList.add('no-transition'));
          void tTrack.offsetHeight; // フォースリフローでトランジション無効化を確定

          // トランジションを無効化してトラックを移動
          tTrack.style.transition = 'none';
          tTrack.style.transform = `translateX(${-currentIndex * cardWidth + centerOffset}%)`;
          
          // アクティブクラスとドットを更新
          slides.forEach((slide, index) => {
            slide.classList.toggle('active', index === currentIndex);
          });

          let realIndex = (currentIndex - 3) % totalRealSlides;
          if (realIndex < 0) realIndex += totalRealSlides;
          dots.forEach((dot, index) => {
            dot.classList.toggle('active', index === realIndex);
          });

          // フォースリフローで変更を確定後、トランジションを復元
          void tTrack.offsetHeight;
          slides.forEach(slide => slide.classList.remove('no-transition'));
        });

        // 初期化とリサイズ対応
        window.addEventListener('resize', () => updateSlider(true));
        updateSlider();
        startAutoplay(); // オートプレイの起動
      }
    </script>
  </body>
</html>
