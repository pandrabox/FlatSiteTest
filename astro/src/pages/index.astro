---
// src/pages/index.astro
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

const currentBase = import.meta.env.BASE_URL;
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <BaseHead title={`${SITE_TITLE} | VRではじめる、もふもふケモノライフ`} description={SITE_DESCRIPTION} />
    <style>
      /* ヒーローセクション */
      .hero {
        position: relative;
        height: calc(100vh - 70px);
        min-height: 550px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, hsl(37, 95%, 72%) 0%, hsl(30, 85%, 45%) 100%);
        overflow: hidden;
        color: var(--color-text-white);
        text-align: center;
        padding: 2rem 1.5rem;
      }

      .hero-bg {
        position: absolute;
        top: 0; left: 0; width: 100%; height: 100%;
        z-index: 1;
        opacity: 0.25;
      }

      .hero-bg img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        filter: blur(4px);
      }

      .hero-content {
        position: relative;
        z-index: 2;
        max-width: 800px;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 1.5rem;
        animation: fadeInUp 1s cubic-bezier(0.16, 1, 0.3, 1);
      }

      .hero-badge {
        background: rgba(255, 255, 255, 0.2);
        backdrop-filter: blur(10px);
        padding: 6px 18px;
        border-radius: 50px;
        font-weight: 700;
        font-size: 0.9rem;
        letter-spacing: 0.05em;
        border: 1px solid rgba(255, 255, 255, 0.3);
      }

      .hero h1 {
        font-size: clamp(2.2rem, 6vw, 4.2rem);
        color: var(--color-text-white);
        line-height: 1.25;
        text-shadow: 0 4px 15px rgba(0,0,0,0.15);
      }

      .hero p {
        font-size: clamp(1rem, 2vw, 1.25rem);
        color: rgba(255, 255, 255, 0.9);
        max-width: 600px;
        line-height: 1.6;
        text-shadow: 0 2px 8px rgba(0,0,0,0.1);
      }

      .hero-actions {
        display: flex;
        gap: 1rem;
        margin-top: 1rem;
      }

      @keyframes fadeInUp {
        from {
          opacity: 0;
          transform: translateY(30px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      /* セクション共通 */
      .section {
        padding: 6rem 1.5rem;
        max-width: 1200px;
        margin: 0 auto;
      }

      .section-header {
        text-align: center;
        max-width: 700px;
        margin: 0 auto 4rem auto;
      }

      .section-header h2 {
        font-size: clamp(1.8rem, 4vw, 2.5rem);
        color: var(--color-text);
        margin-bottom: 1rem;
        position: relative;
        display: inline-block;
      }

      .section-header h2::after {
        content: '🐾';
        position: absolute;
        bottom: -25px;
        left: 50%;
        transform: translateX(-50%);
        font-size: 1.2rem;
      }

      .section-header p {
        color: var(--color-text-muted);
        font-size: 1.05rem;
        margin-top: 1.5rem;
      }

      /* アバターバリエーション紹介 */
      .avatar-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
        gap: 2rem;
      }

      .avatar-card {
        background: var(--color-bg-glass);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-lg);
        overflow: hidden;
        box-shadow: var(--shadow-glass);
        transition: var(--transition-smooth);
        display: flex;
        flex-direction: column;
      }

      .avatar-card:hover {
        transform: translateY(-8px);
        box-shadow: var(--shadow-premium);
        border-color: var(--color-brand);
      }

      .avatar-img-wrapper {
        position: relative;
        aspect-ratio: 1;
        background-color: var(--color-bg-secondary);
        overflow: hidden;
      }

      .avatar-img-wrapper img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: var(--transition-smooth);
      }

      .avatar-card:hover .avatar-img-wrapper img {
        transform: scale(1.05);
      }

      .avatar-badge {
        position: absolute;
        top: 12px;
        right: 12px;
        background: var(--color-brand-dark);
        color: var(--color-text-white);
        font-size: 0.75rem;
        font-weight: 800;
        padding: 4px 10px;
        border-radius: 30px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.1);
      }

      .avatar-info {
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        flex-grow: 1;
        gap: 0.8rem;
      }

      .avatar-info h3 {
        font-size: 1.25rem;
        font-weight: 800;
      }

      .avatar-price {
        font-family: 'Fredoka', sans-serif;
        font-size: 1.35rem;
        font-weight: 700;
        color: var(--color-accent);
      }

      .avatar-desc {
        font-size: 0.9rem;
        color: var(--color-text-muted);
        line-height: 1.5;
      }

      .avatar-rank {
        display: flex;
        gap: 2px;
        color: #FFD700;
        font-size: 0.9rem;
      }

      /* インタラクティブお着替えシミュレータ */
      .stage-container {
        display: grid;
        grid-template-columns: 1.2fr 1fr;
        gap: 3rem;
        align-items: center;
        background: var(--color-bg-glass);
        backdrop-filter: blur(16px);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-lg);
        padding: 3rem;
        box-shadow: var(--shadow-medium);
      }

      .dressing-stage {
        position: relative;
        background: radial-gradient(circle, var(--color-brand-light) 0%, var(--color-bg-secondary) 100%);
        border-radius: var(--radius-md);
        display: flex;
        justify-content: center;
        align-items: center;
        overflow: hidden;
        border: 2px dashed rgba(244, 173, 57, 0.3);
        aspect-ratio: 0.95;
      }

      .tpose-avatar {
        max-height: 85%;
        width: auto;
        object-fit: contain;
        z-index: 1;
        transition: var(--transition-smooth);
      }

      .clothes-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        object-fit: contain;
        z-index: 2;
        pointer-events: none;
        opacity: 0;
        transform: translateY(20px) scale(0.98);
        transition: opacity 0.5s cubic-bezier(0.16, 1, 0.3, 1), transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
        padding: 7.5% 0; /* Adjust to match the scaling of the T-Pose */
      }

      .clothes-overlay.active {
        opacity: 1;
        transform: translateY(0) scale(1);
      }

      .dressing-controls {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
      }

      .dressing-controls h3 {
        font-size: 1.6rem;
        color: var(--color-brand-dark);
      }

      .dressing-controls p {
        color: var(--color-text-muted);
        font-size: 0.95rem;
      }

      .clothes-selector {
        display: flex;
        flex-direction: column;
        gap: 1rem;
      }

      .selector-btn {
        background: var(--color-bg-secondary);
        border: 2px solid transparent;
        padding: 1rem 1.25rem;
        border-radius: var(--radius-md);
        display: flex;
        align-items: center;
        justify-content: space-between;
        cursor: pointer;
        transition: var(--transition-smooth);
        text-align: left;
      }

      .selector-btn:hover {
        background: rgba(244, 173, 57, 0.1);
        border-color: var(--color-brand-light);
      }

      .selector-btn.active {
        background: var(--color-bg);
        border-color: var(--color-brand);
        box-shadow: var(--shadow-soft);
      }

      .selector-btn-label {
        font-weight: 700;
        color: var(--color-text);
        display: flex;
        flex-direction: column;
        gap: 2px;
      }

      .selector-btn-desc {
        font-size: 0.8rem;
        color: var(--color-text-muted);
        font-weight: 500;
      }

      .selector-btn-indicator {
        font-size: 1.2rem;
        opacity: 0;
        transition: var(--transition-fast);
      }

      .selector-btn.active .selector-btn-indicator {
        opacity: 1;
        transform: scale(1.1);
      }

      /* コミュニティショーケース */
      .community-banner {
        position: relative;
        border-radius: var(--radius-lg);
        overflow: hidden;
        min-height: 420px;
        display: flex;
        align-items: center;
        justify-content: flex-start;
        padding: 3rem;
        box-shadow: var(--shadow-medium);
      }

      .community-banner-bg {
        position: absolute;
        top: 0; left: 0; width: 100%; height: 100%;
        z-index: 1;
      }

      .community-banner-bg img {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .community-banner::before {
        content: '';
        position: absolute;
        top: 0; left: 0; width: 100%; height: 100%;
        background: linear-gradient(90deg, rgba(0, 0, 0, 0.6) 0%, rgba(0, 0, 0, 0.2) 100%);
        z-index: 2;
      }

      .community-card {
        position: relative;
        z-index: 3;
        max-width: 480px;
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        padding: 2.5rem;
        border-radius: var(--radius-md);
        box-shadow: 0 20px 40px rgba(0,0,0,0.15);
        border: 1px solid rgba(255, 255, 255, 0.5);
      }

      .community-card h3 {
        font-size: 1.6rem;
        color: var(--color-brand-dark);
        margin-bottom: 1rem;
      }

      .community-card p {
        color: var(--color-text);
        font-size: 0.95rem;
        line-height: 1.6;
        margin-bottom: 1.5rem;
      }

      /* 最後のWelcome CTA */
      .cta-section {
        background: linear-gradient(135deg, hsl(38, 25%, 93%) 0%, hsl(40, 40%, 98%) 100%);
        border-radius: var(--radius-lg);
        text-align: center;
        padding: 5rem 2rem;
        border: 1px solid var(--color-border);
        box-shadow: var(--shadow-glass);
      }

      .cta-section h2 {
        font-size: 2.2rem;
        color: var(--color-brand-dark);
        margin-bottom: 1rem;
      }

      .cta-section p {
        color: var(--color-text-muted);
        max-width: 600px;
        margin: 0 auto 2.5rem auto;
        font-size: 1.05rem;
      }

      /* レスポンシブ */
      @media (max-width: 900px) {
        .stage-container {
          grid-template-columns: 1fr;
          padding: 1.5rem;
          gap: 2rem;
        }

        .community-banner {
          padding: 1.5rem;
          justify-content: center;
          min-height: auto;
        }

        .community-card {
          padding: 1.5rem;
          max-width: 100%;
        }

        .hero-actions {
          flex-direction: column;
          width: 100%;
        }

        .hero-actions .btn {
          width: 100%;
        }
      }
    </style>
  </head>
  <body>
    <Header />

    <!-- 1. ヒーローセクション -->
    <section class="hero">
      <div class="hero-bg">
        <img src={`${currentBase}images/FirstViewPC.webp`} alt="VRChat フラットくんの笑顔が集まる背景画像" />
      </div>
      <div class="hero-content">
        <span class="hero-badge">🐾 非公式フラットファンサイト</span>
        <h1>VRではじめる、<br/>もふもふケモノライフ</h1>
        <p>VRChat向け大人気着ぐるみ体型アバター「フラット」くんの非公式ファンサイトへようこそ！アバターの魅力から、初心者向けアップロード、お着替えの方法まで徹底ガイドします。</p>
        <div class="hero-actions">
          <a href={`${currentBase}guide/`} class="btn btn-primary btn-lg">入門ガイドを見る 🐾</a>
          <a href="#simulator" class="btn btn-secondary btn-lg">お着替えを試す</a>
        </div>
      </div>
    </section>

    <!-- 2. アバター紹介セクション -->
    <section class="section">
      <div class="section-header">
        <h2>アバターバリエーション</h2>
        <p>フラットくんには個性に合わせた4つの公式バリエーションがあります。<br/>あなたの心にピンとくる、お気に入りのフラットくんを見つけましょう！</p>
      </div>

      <div class="avatar-grid">
        <!-- 1. 無印 -->
        <article class="avatar-card">
          <div class="avatar-img-wrapper">
            <img src={`${currentBase}images/FlatNormal.webp`} alt="VRC フラット 無印バージョンアバター画像" />
            <span class="avatar-badge">基本形</span>
          </div>
          <div class="avatar-info">
            <div class="avatar-rank">⭐⭐⭐⭐★</div>
            <h3>フラット (無印)</h3>
            <span class="avatar-price">¥3,000</span>
            <p class="avatar-desc">服のないプレーンな初期バージョン。シンプルなため、配布されている無数のファンメイド衣装をお得に着せ替えたい方に最適！</p>
          </div>
        </article>

        <!-- 2. 2nd -->
        <article class="avatar-card">
          <div class="avatar-img-wrapper">
            <img src={`${currentBase}images/Flat2nd.webp`} alt="VRC フラット 2nd Anniversaryパーカーアバター画像" />
            <span class="avatar-badge">カジュアル</span>
          </div>
          <div class="avatar-info">
            <div class="avatar-rank">⭐⭐⭐⭐★</div>
            <h3>Flat 2nd Anniv.</h3>
            <span class="avatar-price">¥3,980</span>
            <p class="avatar-desc">2周年記念のカジュアル専用ジップパーカー付き。購入してすぐに普段着スタイルで可愛くお出かけできます。</p>
          </div>
        </article>

        <!-- 3. 4th -->
        <article class="avatar-card">
          <div class="avatar-img-wrapper">
            <img src={`${currentBase}images/Flat4th.webp`} alt="VRC フラット 4th Anniversaryサイバーアバター画像" />
            <span class="avatar-badge">管理人イチオシ！</span>
          </div>
          <div class="avatar-info">
            <div class="avatar-rank">⭐⭐⭐⭐⭐</div>
            <h3>Flat 4th Anniv.</h3>
            <span class="avatar-price">¥3,980</span>
            <p class="avatar-desc">4周年を記念したクールなサイバーパンク風ネオン衣装。最新のギミック規格や改変しやすさに最適化された一押しアバター。</p>
          </div>
        </article>

        <!-- 4. IF -->
        <article class="avatar-card">
          <div class="avatar-img-wrapper">
            <img src={`${currentBase}images/FlatIF.webp`} alt="VRC フラット If Verワイルドアバター画像" />
            <span class="avatar-badge">個性派</span>
          </div>
          <div class="avatar-info">
            <div class="avatar-rank">⭐⭐⭐⭐★</div>
            <h3>Flat If Ver</h3>
            <span class="avatar-price">¥3,980</span>
            <p class="avatar-desc">「もしもフラットくんがやんちゃだったら？」のIFアバター。キバののぞく表情やパンキッシュなストリートジャケットが超個性的！</p>
          </div>
        </article>
      </div>
    </section>

    <!-- 3. インタラクティブお着替えシミュレータセクション -->
    <section class="section" id="simulator">
      <div class="section-header">
        <h2>あなただけのフラットくんに</h2>
        <p>公式衣装からファンメイドの可愛い服まで。アバターはお着替え（改変）することで無限の個性を放ちます。ゲーム内のお着替えイメージを今すぐ体験！</p>
      </div>

      <div class="stage-container">
        <!-- Stage Frame (Left) -->
        <div class="dressing-stage">
          <!-- Base T-pose Flat -->
          <img class="tpose-avatar" id="tposeAvatar" src={`${currentBase}images/FlatTPose.webp`} alt="お着替えシミュレータ用 Tポーズのフラットくんベースアバター" />
          
          <!-- Clothes Overlay (Toggled via JS) -->
          <img class="clothes-overlay" id="clothesOverlay1" src={`${currentBase}images/Clothes1.webp`} alt="フラットくん用カジュアルコートオーバーレイ" />
        </div>

        <!-- Controls Frame (Right) -->
        <div class="dressing-controls">
          <h3>お着替えクローゼット 👗</h3>
          <p>ボタンをクリックすると、フラットくんに衣装を着せたり、脱がせたりすることができます。アウターのフィット感をチェック！</p>
          
          <div class="clothes-selector">
            <button class="selector-btn active" id="btnBase">
              <span class="selector-btn-label">
                <span>素体モード (T-Pose)</span>
                <span class="selector-btn-desc">お着替え前のすっきりとした状態</span>
              </span>
              <span class="selector-btn-indicator">👀</span>
            </button>

            <button class="selector-btn" id="btnClothes1">
              <span class="selector-btn-label">
                <span>モフモフカジュアルアウター 🧥</span>
                <span class="selector-btn-desc">オーバーサイズのファンメイド秋冬コート</span>
              </span>
              <span class="selector-btn-indicator">✨</span>
            </button>
          </div>

          <div style="margin-top: 1rem; border-top: 1px solid var(--color-border); padding-top: 1.5rem;">
            <p style="font-size: 0.85rem; color: var(--color-text-muted); margin-bottom: 1rem;">※Modular Avatarという無料の拡張ツールを使えば、この着せ替えがUnity上でドラッグ＆ドロップだけで完全再現できます。</p>
            <a href={`${currentBase}outfits/`} class="btn btn-secondary" style="width: 100%;">衣装＆カスタムアセットをもっと見る</a>
          </div>
        </div>
      </div>
    </section>

    <!-- 4. コミュニティセクション -->
    <section class="section">
      <div class="community-banner">
        <div class="community-banner-bg">
          <img src={`${currentBase}images/Meetup.webp`} alt="100人以上のフラットくんが集結した大迫力の定例集会写真" />
        </div>
        <div class="community-card">
          <h3>あたたかいコミュニティ 💛</h3>
          <p>フラットくんの仲間たちは非常にフレンドリー！年に1度開催される定例集会には100名以上のオーナーが大集合し、お揃いの衣装や改変を持ち寄ってお祝いします。</p>
          <a href={`${currentBase}community/`} class="btn btn-primary">コミュニティの詳細を見る</a>
        </div>
      </div>
    </section>

    <!-- 5. 最後のCTAセクション -->
    <section class="section">
      <div class="cta-section">
        <h2>さあ、もふもふの世界へ会いにいこう</h2>
        <p>VRChatの始め方がわからなくても大丈夫！アバターの選び方から、購入、Unityでのアップロード設定までを、初心者向けに優しく1からガイドします。</p>
        <a href={`${currentBase}guide/`} class="btn btn-accent btn-lg" style="font-size: 1.2rem; padding: 15px 45px;">
          入門ガイドを見る (全7ステップ) 🐾
        </a>
      </div>
    </section>

    <Footer />

    <script>
      // Interactive Closet Logic
      const btnBase = document.getElementById('btnBase');
      const btnClothes1 = document.getElementById('btnClothes1');
      const clothesOverlay1 = document.getElementById('clothesOverlay1');

      if (btnBase && btnClothes1 && clothesOverlay1) {
        btnBase.addEventListener('click', () => {
          // Remove active class from buttons
          btnBase.classList.add('active');
          btnClothes1.classList.remove('active');
          
          // Hide overlay
          clothesOverlay1.classList.remove('active');
        });

        btnClothes1.addEventListener('click', () => {
          // Toggle active class on buttons
          btnClothes1.classList.add('active');
          btnBase.classList.remove('active');

          // Show overlay with transition
          clothesOverlay1.classList.add('active');
        });
      }
    </script>
  </body>
</html>
