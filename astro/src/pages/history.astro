---
// src/pages/history.astro
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const SEO_TITLE = "フラットくんの歩んできた歴史 | フラットファンクラブ";
const SEO_DESCRIPTION = "アバター「フラット」くんのアップデート履歴から、歴代の定例集会・撮影会の開催記録まで、もふもふアバターの進化の歩みを振り返るタイムライン！";
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <BaseHead title={SEO_TITLE} description={SEO_DESCRIPTION} />
    <style>
      .page-hero {
        background: linear-gradient(135deg, hsl(37, 95%, 72%) 0%, hsl(30, 85%, 45%) 100%);
        color: var(--color-text-white);
        padding: 5rem 1.5rem;
        text-align: center;
        border-radius: 0 0 var(--radius-lg) var(--radius-lg);
      }

      .page-hero h1 {
        font-size: clamp(2rem, 5vw, 3.2rem);
        color: var(--color-text-white);
        margin-bottom: 1rem;
        font-weight: 900;
        text-shadow: 0 4px 10px rgba(0,0,0,0.1);
      }

      .page-hero p {
        font-size: clamp(0.95rem, 2vw, 1.15rem);
        color: rgba(255, 255, 255, 0.9);
        max-width: 600px;
        margin: 0 auto;
      }

      .history-container {
        max-width: 900px;
        margin: 4rem auto;
        padding: 0 1.5rem;
      }

      .history-section-title {
        text-align: center;
        font-size: 1.8rem;
        color: var(--color-brand-dark);
        margin-top: 5rem;
        margin-bottom: 3rem;
        position: relative;
      }

      .history-section-title::after {
        content: '';
        position: absolute;
        bottom: -10px;
        left: 50%;
        transform: translateX(-50%);
        width: 50px;
        height: 3px;
        background-color: var(--color-accent);
        border-radius: 2px;
      }

      /* Vertical Timeline */
      .timeline {
        position: relative;
        padding-left: 50px;
      }

      .timeline::before {
        content: '';
        position: absolute;
        top: 0;
        bottom: 0;
        left: 20px;
        width: 4px;
        background: rgba(244, 173, 57, 0.2);
        border-radius: 2px;
      }

      .timeline-item {
        position: relative;
        margin-bottom: 3rem;
      }

      .timeline-badge {
        position: absolute;
        left: -42px;
        top: 4px;
        width: 20px;
        height: 20px;
        border-radius: 50%;
        background-color: var(--color-brand);
        border: 4px solid var(--color-bg);
        box-shadow: 0 0 0 4px rgba(244, 173, 57, 0.1);
        z-index: 2;
        transition: var(--transition-fast);
      }

      .timeline-item:hover .timeline-badge {
        background-color: var(--color-accent);
        box-shadow: 0 0 0 6px rgba(231, 76, 60, 0.2);
        transform: scale(1.2);
      }

      .timeline-card {
        background: var(--color-bg-glass);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-md);
        padding: 1.75rem;
        box-shadow: var(--shadow-glass);
        transition: var(--transition-smooth);
      }

      .timeline-card:hover {
        transform: translateX(4px);
        box-shadow: var(--shadow-medium);
        border-color: var(--color-brand-light);
      }

      .timeline-date {
        font-family: 'Fredoka', sans-serif;
        font-size: 0.95rem;
        font-weight: 700;
        color: var(--color-accent);
        margin-bottom: 6px;
      }

      .timeline-title {
        font-size: 1.25rem;
        font-weight: 800;
        color: var(--color-text);
        margin-bottom: 10px;
      }

      .timeline-desc {
        color: var(--color-text-muted);
        font-size: 0.9rem;
        line-height: 1.6;
      }

      .version-tag {
        display: inline-block;
        background-color: var(--color-brand-light);
        color: var(--color-text-white);
        font-size: 0.7rem;
        font-weight: 800;
        padding: 2px 10px;
        border-radius: 20px;
        margin-left: 8px;
        font-family: 'Fredoka', sans-serif;
        vertical-align: middle;
      }

      @media (max-width: 600px) {
        .timeline {
          padding-left: 35px;
        }

        .timeline::before {
          left: 10px;
        }

        .timeline-badge {
          left: -31px;
        }
      }
    </style>
  </head>
  <body>
    <Header />

    <!-- Page Hero -->
    <header class="page-hero">
      <h1>フラットくんの歩んだ歴史</h1>
      <p>初リリースから現在に至るアバターアップデートの軌跡、<br/>そしてオーナーたちと紡いできた楽しいイベント集会の思い出アルバムです。</p>
    </header>

    <main class="history-container">
      
      <!-- アバター開発の歩み -->
      <h2 class="history-section-title">アバター開発・アップデートログ ⚙️</h2>
      
      <div class="timeline">
        
        <!-- 4th -->
        <article class="timeline-item">
          <div class="timeline-badge"></div>
          <div class="timeline-card">
            <div class="timeline-date">2026.01.28</div>
            <h3 class="timeline-title">フラット 4th Anniversary 発売！<span class="version-tag">v4.0</span></h3>
            <p class="timeline-desc">
              フラット4周年を記念したフルリメイクモデルが発売されました。近未来風サイバーネオン衣装を初期装備し、PhysBones設定を完全近代化。表情アニメーションやMA（Modular Avatar）との互換性が劇的に強化されました。
            </p>
          </div>
        </article>

        <!-- If -->
        <article class="timeline-item">
          <div class="timeline-badge"></div>
          <div class="timeline-card">
            <div class="timeline-date">2025.10.14</div>
            <h3 class="timeline-title">フラット If Ver リリース！<span class="version-tag">v3.0</span></h3>
            <p class="timeline-desc">
              「もしもやんちゃ系だったら？」のパラレルコンセプトアバター。牙を少し出した可愛いワイルドな表情と、ストリートパンクジャケットを初期装備した個性派モデルとして人気を博しました。
            </p>
          </div>
        </article>

        <!-- 2nd -->
        <article class="timeline-item">
          <div class="timeline-badge"></div>
          <div class="timeline-card">
            <div class="timeline-date">2024.05.27</div>
            <h3 class="timeline-title">フラット 2nd Anniversary リリース！<span class="version-tag">v2.0</span></h3>
            <p class="timeline-desc">
              2周年記念モデル。現在でも人気の高いカジュアル専用パーカー衣装を搭載。Unity 2019への対応やアバター動作設定が一部軽量化・洗練されました。
            </p>
          </div>
        </article>

        <!-- Normal -->
        <article class="timeline-item">
          <div class="timeline-badge"></div>
          <div class="timeline-card">
            <div class="timeline-date">2022.01.06</div>
            <h3 class="timeline-title">初代「フラット」販売開始！<span class="version-tag">v1.0</span></h3>
            <p class="timeline-desc">
              らすちんワークスより、VRChat向けオリジナルケモノアバター「フラット」が誕生。着ぐるみ体型という独自の親しみやすさと、驚異的な愛らしさでケモナーコミュニティで瞬く間に話題となりました。
            </p>
          </div>
        </article>

      </div>

      <!-- コミュニティイベントの歩み -->
      <h2 class="history-section-title">コミュニティ・集会開催記録 📷</h2>

      <div class="timeline">
        
        <article class="timeline-item">
          <div class="timeline-badge"></div>
          <div class="timeline-card">
            <div class="timeline-date">2025.10.12</div>
            <h3 class="timeline-title">第5回 フラット定例集会 開催</h3>
            <p class="timeline-desc">
              4th Anniversaryモデルの普及に伴い、参加者数が過去最多の**112名**を突破！専用のお祝いカフェ特設ワールドにて、個性豊かな改変フラットくんたちが一堂に会し記念撮影を行いました。
            </p>
          </div>
        </article>

        <article class="timeline-item">
          <div class="timeline-badge"></div>
          <div class="timeline-card">
            <div class="timeline-date">2024.10.05</div>
            <h3 class="timeline-title">第4回 フラット定例集会 開催</h3>
            <p class="timeline-desc">
              「サイバーネオン」をテーマに開催。全員でサイバー服の発光色をカスタマイズして暗闇の特設ダンスホールで踊る、未来的な大集会となりました。
            </p>
          </div>
        </article>

        <article class="timeline-item">
          <div class="timeline-badge"></div>
          <div class="timeline-card">
            <div class="timeline-date">2023.09.28</div>
            <h3 class="timeline-title">第3回 フラット定例集会 開催</h3>
            <p class="timeline-desc">
              If Verの発売を受けて、やんちゃ服とパーカー服の対抗写真コンテストを開催。定例としては初の100名規模に近い盛況となりました。
            </p>
          </div>
        </article>

        <article class="timeline-item">
          <div class="timeline-badge"></div>
          <div class="timeline-card">
            <div class="timeline-date">2021.08.01</div>
            <h3 class="timeline-title">第1回 フラットお誕生日記念撮影会</h3>
            <p class="timeline-desc">
              フラット発売1周年を祝うファン主導のミニ撮影イベント。約20名のフラットくんたちが集まり、お誕生日ワールドでお祝いしました。これが現在の定例集会の基礎となりました。
            </p>
          </div>
        </article>

      </div>

    </main>

    <Footer />
  </body>
</html>
