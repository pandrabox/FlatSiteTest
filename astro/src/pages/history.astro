---
// src/pages/history.astro
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const SEO_TITLE = "フラットくんの歩んできた歴史 | フラットファンクラブ";
const SEO_DESCRIPTION = "アバター「フラット」くんのアップデート履歴から、歴代の定例集会・撮影会の開催記録まで、もふもふアバターの進化の歩みを振り返るタイムライン！";

const currentBase = import.meta.env.BASE_URL + '/';

const avatarHistory = [
  {
    date: "2026.01.28",
    version: "v4.0",
    title: "フラット 4th Anniversary 発売！",
    desc: "フラット4周年を記念したフルリメイクモデルが発売されました。近未来風サイバーネオン衣装を初期装備し、PhysBones設定を完全近代化。表情アニメーションやMA（Modular Avatar）との互換性が劇的に強化されました。",
    image: "Flat4th.webp"
  },
  {
    date: "2025.10.14",
    version: "v3.0",
    title: "フラット If Ver リリース！",
    desc: "「もしもやんちゃ系だったら？」のパラレルコンセプトアバター。牙を少し出した可愛いワイルドな表情と、ストリートパンクジャケットを初期装備した個性派モデルとして人気を博しました。",
    image: "FlatIF.webp"
  },
  {
    date: "2024.05.27",
    version: "v2.0",
    title: "フラット 2nd Anniversary リリース！",
    desc: "2周年記念モデル。現在でも人気の高いカジュアル専用パーカー衣装を搭載。Unity 2019への対応やアバター動作設定が一部軽量化・洗練されました。",
    image: "Flat2nd.webp"
  },
  {
    date: "2022.01.06",
    version: "v1.0",
    title: "初代「フラット」販売開始！",
    desc: "らすちんワークスより、VRChat向けオリジナルケモノアバター「フラット」が誕生。着ぐるみ体型という独自の親しみやすさと、驚異的な愛らしさでケモナーコミュニティで瞬く間に話題となりました。",
    image: "FlatNormal.webp"
  }
];

const meetingHistory = [
  {
    num: 10,
    date: "2026年7月4日",
    rawDate: "2026.07.04",
    image: "10_20260704.webp"
  },
  {
    num: 9,
    date: "2026年2月1日",
    rawDate: "2026.02.01",
    image: "9_20260201.webp"
  },
  {
    num: 8,
    date: "2025年10月19日",
    rawDate: "2025.10.19",
    image: "8_20251019.webp"
  },
  {
    num: 7,
    date: "2025年7月5日",
    rawDate: "2025.07.05",
    image: "7_20250705.webp"
  },
  {
    num: 6,
    date: "2023年8月5日",
    rawDate: "2023.08.05",
    image: "6_20230805.webp"
  },
  {
    num: 5,
    date: "2023年1月8日",
    rawDate: "2023.01.08",
    image: "5_20230108.webp"
  },
  {
    num: 4,
    date: "2022年10月7日",
    rawDate: "2022.10.07",
    image: "4_20221007.webp"
  },
  {
    num: 3,
    date: "2022年4月23日",
    rawDate: "2022.04.23",
    image: "3_20220423.webp"
  },
  {
    num: 2,
    date: "2022年2月5日",
    rawDate: "2022.02.05",
    image: "2_20220205.webp"
  },
  {
    num: 1,
    date: "2022年1月8日",
    rawDate: "2022.01.08",
    image: "1_20220108.webp"
  }
];
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <BaseHead title={SEO_TITLE} description={SEO_DESCRIPTION} />
    <style>
      .page-hero {
        background: linear-gradient(135deg, hsl(37, 95%, 72%) 0%, hsl(30, 85%, 45%) 100%);
        color: var(--color-text-white);
        padding: 5rem 1.5rem;
        text-align: center;
        border-radius: 0 0 var(--radius-lg) var(--radius-lg);
      }

      .page-hero h1 {
        font-size: clamp(2rem, 5vw, 3.2rem);
        color: var(--color-text-white);
        margin-bottom: 1rem;
        font-weight: 900;
        text-shadow: 0 4px 10px rgba(0,0,0,0.1);
      }

      .page-hero p {
        font-size: clamp(0.95rem, 2vw, 1.15rem);
        color: rgba(255, 255, 255, 0.9);
        max-width: 600px;
        margin: 0 auto;
      }

      .history-container {
        max-width: 900px;
        margin: 4rem auto;
        padding: 0 1.5rem;
      }

      .history-section-title {
        text-align: center;
        font-size: 1.8rem;
        color: var(--color-brand-dark);
        margin-top: 5rem;
        margin-bottom: 3rem;
        position: relative;
      }

      .history-section-title::after {
        content: '';
        position: absolute;
        bottom: -10px;
        left: 50%;
        transform: translateX(-50%);
        width: 50px;
        height: 3px;
        background-color: var(--color-accent);
        border-radius: 2px;
      }

      /* Vertical Timeline */
      .timeline {
        position: relative;
        padding-left: 50px;
      }

      .timeline::before {
        content: '';
        position: absolute;
        top: 0;
        bottom: 0;
        left: 20px;
        width: 4px;
        background: rgba(244, 173, 57, 0.2);
        border-radius: 2px;
      }

      .timeline-item {
        position: relative;
        margin-bottom: 3rem;
      }

      .timeline-badge {
        position: absolute;
        left: -42px;
        top: 4px;
        width: 20px;
        height: 20px;
        border-radius: 50%;
        background-color: var(--color-brand);
        border: 4px solid var(--color-bg);
        box-shadow: 0 0 0 4px rgba(244, 173, 57, 0.1);
        z-index: 2;
        transition: var(--transition-fast);
      }

      .timeline-item:hover .timeline-badge {
        background-color: var(--color-accent);
        box-shadow: 0 0 0 6px rgba(231, 76, 60, 0.2);
        transform: scale(1.2);
      }

      .timeline-card {
        background: var(--color-bg-glass);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-md);
        padding: 1.75rem;
        box-shadow: var(--shadow-glass);
        transition: var(--transition-smooth);
      }

      .timeline-card:hover {
        transform: translateX(4px);
        box-shadow: var(--shadow-medium);
        border-color: var(--color-brand-light);
      }

      .timeline-date {
        font-family: 'Fredoka', sans-serif;
        font-size: 0.95rem;
        font-weight: 700;
        color: var(--color-accent);
        margin-bottom: 6px;
      }

      .timeline-title {
        font-size: 1.25rem;
        font-weight: 800;
        color: var(--color-text);
        margin-bottom: 10px;
      }

      .timeline-desc {
        color: var(--color-text-muted);
        font-size: 0.9rem;
        line-height: 1.6;
      }

      .version-tag {
        display: inline-block;
        background-color: var(--color-brand-light);
        color: var(--color-text-white);
        font-size: 0.7rem;
        font-weight: 800;
        padding: 2px 10px;
        border-radius: 20px;
        margin-left: 8px;
        font-family: 'Fredoka', sans-serif;
        vertical-align: middle;
      }

      .timeline-card-inner {
        display: flex;
        gap: 1.25rem;
        align-items: flex-start;
      }

      .timeline-img-wrapper {
        width: 160px;
        height: auto;
        flex-shrink: 0;
        border-radius: var(--radius-sm);
        overflow: hidden;
        background-color: var(--color-bg-secondary);
        border: 1px solid var(--color-border);
        display: flex;
        align-items: flex-start;
        justify-content: center;
        box-shadow: var(--shadow-glass);
      }

      .timeline-img {
        width: 100%;
        height: auto;
        display: block;
        transition: var(--transition-smooth);
      }

      .timeline-card:hover .timeline-img {
        transform: scale(1.05);
      }

      .timeline-info {
        flex-grow: 1;
      }

      @media (max-width: 600px) {
        .timeline {
          padding-left: 35px;
        }

        .timeline::before {
          left: 10px;
        }

        .timeline-badge {
          left: -31px;
        }

        .timeline-card {
          padding: 1.25rem;
        }

        .timeline-card-inner {
          gap: 1rem;
        }

        .timeline-img-wrapper {
          width: 140px;
        }
      }

      /* Poster Grid & Cards */
      .poster-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
        gap: 2rem;
        margin-top: 2rem;
        margin-bottom: 4rem;
      }

      .poster-card {
        background: var(--color-bg-glass);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-md);
        overflow: hidden;
        box-shadow: var(--shadow-glass);
        transition: var(--transition-smooth);
        display: flex;
        flex-direction: column;
      }

      .poster-card:hover {
        transform: translateY(-6px);
        box-shadow: var(--shadow-medium);
        border-color: var(--color-brand);
      }

      .poster-image-wrapper {
        position: relative;
        overflow: hidden;
        height: 280px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: rgba(244, 173, 57, 0.05);
        border-bottom: 1px solid var(--color-border);
      }

      .poster-image {
        max-width: 100%;
        max-height: 100%;
        width: auto;
        height: auto;
        object-fit: contain;
        transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
      }

      .poster-card:hover .poster-image {
        transform: scale(1.06);
      }

      .poster-info {
        padding: 1.25rem;
        display: flex;
        flex-direction: column;
        gap: 0.4rem;
      }

      .poster-badge {
        font-family: 'Fredoka', sans-serif;
        font-size: 0.75rem;
        font-weight: 800;
        color: var(--color-accent);
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }

      .poster-title {
        font-size: 1.1rem;
        font-weight: 800;
        color: var(--color-text);
        margin: 0;
        line-height: 1.4;
      }

      .poster-date {
        font-family: 'Fredoka', sans-serif;
        font-size: 0.85rem;
        color: var(--color-text-muted);
        margin-top: 0.2rem;
      }
    </style>
  </head>
  <body>
    <Header />

    <!-- Page Hero -->
    <header class="page-hero">
      <h1>フラットくんの歩んだ歴史</h1>
      <p>初リリースから現在に至るアバターアップデートの軌跡、<br/>そしてオーナーたちと紡いできた楽しいイベント集会の思い出アルバムです。</p>
    </header>

    <main class="history-container">
      
      <!-- アバター開発の歩み -->
      <h2 class="history-section-title">アバター開発・アップデートログ ⚙️</h2>
      
      <div class="timeline">
        {avatarHistory.map((item) => (
          <article class="timeline-item">
            <div class="timeline-badge"></div>
            <div class="timeline-card">
              <div class="timeline-card-inner">
                {item.image && (
                  <div class="timeline-img-wrapper">
                    <img
                      src={`${currentBase}images/${item.image}`}
                      alt={`${item.title} アバター画像`}
                      class="timeline-img"
                      loading="lazy"
                      decoding="async"
                    />
                  </div>
                )}
                <div class="timeline-info">
                  <div class="timeline-date">{item.date}</div>
                  <h3 class="timeline-title">
                    {item.title}
                    <span class="version-tag">{item.version}</span>
                  </h3>
                  <p class="timeline-desc">{item.desc}</p>
                </div>
              </div>
            </div>
          </article>
        ))}
      </div>

      <!-- コミュニティイベントの歩み -->
      <h2 class="history-section-title">歴代の集会 📷</h2>

      <div class="poster-grid">
        {meetingHistory.map((meeting) => (
          <article class="poster-card">
            <div class="poster-image-wrapper">
              <img
                src={`${currentBase}images/history/${meeting.image}`}
                alt={`第${meeting.num}回 フラット集会 ポスター`}
                class="poster-image"
                loading="lazy"
                decoding="async"
              />
            </div>
            <div class="poster-info">
              <span class="poster-badge">MEETUP #{meeting.num}</span>
              <h3 class="poster-title">第{meeting.num}回 フラット集会</h3>
              <time datetime={meeting.rawDate} class="poster-date">
                📅 {meeting.date}
              </time>
            </div>
          </article>
        ))}
      </div>

    </main>

    <Footer />
  </body>
</html>
