---
// src/pages/community.astro
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const currentBase = import.meta.env.BASE_URL + '/';

const SEO_TITLE = "フラットくんの温かいコミュニティ | フラットファンクラブ";
const SEO_DESCRIPTION = "アバター「フラット」くんのオーナーたちが集まる、愛にあふれたコミュニティの紹介。年1回100名以上が集まる大集会や、日々の交流情報をお届け！";

const meetups = [
  {
    num: 9,
    date: "2026.02.01",
    title: "第9回 フラット集会",
    desc: "リニューアルモデル（4周年記念版など）がお披露目され、歴代最高に表現力豊かでカラフルなフラットくんたちが一堂に会しました。衣装のバリエーションもさらに広がり、笑顔に満ちた素晴らしい思い出の写真となりました。",
    images: ["meetup_9-1.webp", "meetup_9-2.webp"],
    captions: [
      "黄色の波！可愛さが限界突破した第9回フラット集会の記念撮影写真です。",
      "色とりどりの個性豊かな衣装を着こなす、おしゃれなフラットくんたち。"
    ]
  },
  {
    num: 8,
    date: "2025.10.19",
    title: "第8回 フラット集会",
    desc: "パラレルコンセプトアバター「If Ver」などの参加もあり、多様な表情とスタイルが光った第8回。それぞれのオーナーがこだわり抜いた表情やポージングで、賑やかで息の合った並びとなりました。",
    images: ["meetup_8-1.webp", "meetup_8-2.webp"],
    captions: [
      "ぎゅっと集まってハイ、ポーズ！もふもふの温もりが伝わる1枚です。",
      "アバターの魅力をそれぞれ引き出したポーズで並びました。"
    ]
  },
  {
    num: 7,
    date: "2025.07.05",
    title: "第7回 フラット集会",
    desc: "夏のはじまりを告げる第7回集会。多くの新しいオーナー様も加わり、初めての参加でも温かく包み込むコミュニティの優しさがあふれるイベントとなりました。サンプルアバターでの参加者も多数いました。",
    images: ["meetup_7-1.webp", "meetup_7-2.webp"],
    captions: [
      "大人数でもぴったり整列！みんなのフラット愛が一つになった瞬間です。",
      "初めての参加者もすぐに馴染める、終始なごやかな雰囲気でした。"
    ]
  },
  {
    num: 6,
    date: "2023.08.05",
    title: "第6回 フラット集会",
    desc: "暑さを吹き飛ばすような元気いっぱいのフラットたちが大集結！PhysBones等のギミックでお互いのもふもふ感を確かめ合ったり、仕草を真似し合ったりと、VRChatならではの一体感が生まれました。",
    images: ["meetup_6-1.webp", "meetup_6-2.webp"],
    captions: [
      "ワールドのステージいっぱいに広がる、幸せいっぱいのフラットくんたち。",
      "手をつないだり、ポーズを合わせたりして楽しむオーナーたち。"
    ]
  },
  {
    num: 5,
    date: "2023.01.08",
    title: "第5回 フラット集会",
    desc: "新年の幕開けとともに開催された、節目の第5回集会。コミュニティの規模も順調に拡大し、イベント自体の進行も洗練され、お互いの衣装やカスタムの自慢大会も非常に盛り上がりました。",
    images: ["meetup_5.webp"],
    captions: [
      "新年を祝う、笑顔あふれる第5回フラット集会の記念撮影。"
    ]
  },
  {
    num: 4,
    date: "2022.10.07",
    title: "第4回 フラット集会",
    desc: "秋の夜長に開催された第4回。アバター向けの対応衣装やアクセサリーがBOOTHなどで多数発表され始め、初期衣装だけでなく自分だけのコーディネートでオシャレに着飾ったフラットくんたちが増えていきました。",
    images: ["meetup_4-1.webp", "meetup_4-2.webp"],
    captions: [
      "それぞれの「うちの子」の個性が光る、コーディネート豊かな記念写真。",
      "カメラ目線でばっちり！仲の良さがうかがえます。"
    ]
  },
  {
    num: 3,
    date: "2022.04.23",
    title: "第3回 フラット集会",
    desc: "春の暖かさに包まれた第3回。少しずつ定例の集まりとしての認知度も高まり、「フラットくんを使っているフレンドに会いたい！」という理由で新しくアバターを購入して参加してくれる方も増え始めました。",
    images: ["meetup_3-1.webp", "meetup_3-2.webp"],
    captions: [
      "春の陽気のようにぽかぽか温かい、みんなの仲良し集合写真。",
      "アバターの可愛いギミックを動かして、みんなでわいわい！"
    ]
  },
  {
    num: 2,
    date: "2022.02.05",
    title: "第2回 フラット集会",
    desc: "発売から1ヶ月を経て開催された第2回集会。初代リリースの興奮が冷めやらぬ中、VRChat上のケモノコミュニティ内で「めちゃくちゃ可愛いアバターがある！」と広まり、参加人数が前回の倍以上に膨らみました。",
    images: ["meetup_2-1.webp", "meetup_2-2.webp"],
    captions: [
      "アバター発売から早くも賑わいを見せる、大満足の第2回記念撮影。",
      "黄色くて丸いフォルムの魅力がたっぷり詰まったスクショです。"
    ]
  },
  {
    num: 1,
    date: "2022.01.08",
    title: "第1回 フラット集会",
    desc: "アバター「フラット」くんの販売開始（1月6日）からわずか2日後に行われた、伝説 of 伝説の第1回集会。まだ限られたオーナー数でしたが、この小さなもふもふの輪が、現在の100名を超える大コミュニティの第一歩となりました。",
    images: ["meetup_1.webp"],
    captions: [
      "ここからすべてが始まった！記念すべき第1回目のアットホームな集合写真。"
    ]
  }
];

const regularEvents = [
  {
    title: "和風かふぇ ひだまり",
    badge: "第1・第3火曜日 22:00〜",
    desc: "フラット集会協賛イベントであり、アットホームな和風の雰囲気のなかでお喋りを楽しむカフェ。フラットくんオーナーやファンたちがのんびりと集まり、日頃の出来事を語り合っています。見学アバターでの来店や、VRChat初心者の方へのサポートも丁寧に行われています。",
    images: ["hidamari_hidamari1.webp", "hidamari_hidamari2.webp"],
    captions: [
      "ひだまりの穏やかな和風空間で、お座敷を囲んでくつろぐフラットくんたち。",
      "店内でまったり。誰でも優しく迎え入れる温かい雰囲気が魅力です。"
    ]
  },
  {
    title: "KemonoBar ずんどこ",
    badge: "毎週金曜日 22:00〜",
    desc: "フラット族の「コモドくん」がマスターを務める、ケモノたちのための金曜夜のバー。毎週多くのケモノ系アバターユーザーで大盛況となり、フラットくんたちのたまり場としても親しまれています。陽気で楽しいお喋りと、音楽やトークでにぎやかに週末の夜を過ごしたい方に最高の場所です。",
    images: ["zundoko.webp"],
    captions: [
      "毎週大盛況！マスターのコモドくんを中心に、笑顔と会話が溢れるずんどこの夜。"
    ]
  }
];
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <BaseHead title={SEO_TITLE} description={SEO_DESCRIPTION} />
    <style>
      .page-hero {
        background: linear-gradient(135deg, hsl(37, 95%, 72%) 0%, hsl(30, 85%, 45%) 100%);
        color: var(--color-text-white);
        padding: 6rem 1.5rem;
        text-align: center;
        border-radius: 0 0 var(--radius-lg) var(--radius-lg);
        position: relative;
        overflow: hidden;
      }

      .page-hero::before {
        content: "";
        position: absolute;
        top: 0; left: 0; right: 0; bottom: 0;
        background: radial-gradient(circle at 80% 20%, rgba(255, 255, 255, 0.15) 0%, transparent 50%);
        pointer-events: none;
      }

      .hero-badge {
        display: inline-block;
        background: rgba(255, 255, 255, 0.2);
        backdrop-filter: blur(4px);
        color: var(--color-text-white);
        font-size: 0.85rem;
        font-weight: 800;
        padding: 6px 16px;
        border-radius: 50px;
        margin-bottom: 1.5rem;
        letter-spacing: 0.15em;
      }

      .page-hero h1 {
        font-size: clamp(2.2rem, 6vw, 3.6rem);
        color: var(--color-text-white);
        margin-bottom: 1.2rem;
        font-weight: 900;
        text-shadow: 0 4px 15px rgba(0,0,0,0.15);
      }

      .page-hero p {
        font-size: clamp(1rem, 2.2vw, 1.25rem);
        color: rgba(255, 255, 255, 0.95);
        max-width: 700px;
        margin: 0 auto;
        line-height: 1.8;
      }

      .intro-container {
        display: grid;
        grid-template-columns: 1.2fr 1fr;
        gap: 4rem;
        margin: 5rem auto;
        max-width: 1200px;
        padding: 0 1.5rem;
        align-items: center;
      }

      .intro-text h2 {
        font-size: 2.2rem;
        color: var(--color-brand-dark);
        margin-bottom: 1.5rem;
        position: relative;
        display: inline-block;
      }

      .intro-text h2::after {
        content: "";
        position: absolute;
        bottom: -8px; left: 0;
        width: 60px; height: 4px;
        background: var(--color-accent);
        border-radius: 2px;
      }

      .intro-text p {
        color: var(--color-text);
        line-height: 1.85;
        font-size: 1.05rem;
        margin-bottom: 1.5rem;
      }

      .stats-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1.5rem;
      }

      .stat-card {
        background: var(--color-bg-glass);
        backdrop-filter: blur(10px);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-md);
        padding: 2rem 1.5rem;
        text-align: center;
        box-shadow: var(--shadow-glass);
        transition: var(--transition-smooth);
      }

      .stat-card:hover {
        transform: translateY(-4px);
        box-shadow: var(--shadow-medium);
        border-color: var(--color-brand);
      }

      .stat-num {
        font-family: 'Fredoka', sans-serif;
        font-size: 3rem;
        font-weight: 800;
        color: var(--color-brand-dark);
        line-height: 1.1;
        margin-bottom: 8px;
        text-shadow: 0 2px 4px rgba(244, 173, 57, 0.1);
      }

      .stat-label {
        font-size: 0.9rem;
        color: var(--color-text-muted);
        font-weight: 700;
      }

      /* Sections General */
      .section-title-wrapper {
        text-align: center;
        margin: 6rem auto 3rem auto;
        max-width: 750px;
        padding: 0 1.5rem;
      }

      .section-title-wrapper h2 {
        font-size: 2.2rem;
        color: var(--color-text);
        margin-bottom: 1rem;
        position: relative;
        display: inline-block;
      }

      .section-title-wrapper p {
        color: var(--color-text-muted);
        font-size: 1.05rem;
        margin-top: 0.5rem;
      }

      /* Timeline Layout (Meetups) */
      .timeline {
        position: relative;
        max-width: 1000px;
        margin: 0 auto;
        padding: 1rem 1.5rem 4rem 1.5rem;
      }

      .timeline::before {
        content: "";
        position: absolute;
        top: 0; bottom: 0; left: 2.5rem;
        width: 4px;
        background: linear-gradient(to bottom, var(--color-brand-light) 0%, rgba(244, 173, 57, 0.05) 100%);
        border-radius: 4px;
      }

      .timeline-item {
        position: relative;
        margin-bottom: 4rem;
        padding-left: 5rem;
      }

      .timeline-badge {
        position: absolute;
        left: 1.6rem;
        top: 1.5rem;
        width: 2rem;
        height: 2rem;
        background: var(--color-bg);
        border: 4px solid var(--color-brand);
        border-radius: 50%;
        z-index: 2;
        box-shadow: 0 0 0 4px rgba(244, 173, 57, 0.15);
        transition: var(--transition-fast);
      }

      .timeline-item:hover .timeline-badge {
        background: var(--color-brand);
        border-color: var(--color-accent);
        box-shadow: 0 0 0 6px rgba(231, 76, 60, 0.2);
        transform: scale(1.15);
      }

      .timeline-content {
        background: var(--color-bg-glass);
        backdrop-filter: blur(10px);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-md);
        padding: 2.5rem;
        box-shadow: var(--shadow-glass);
        transition: var(--transition-smooth);
      }

      .timeline-content:hover {
        transform: translateY(-4px);
        box-shadow: var(--shadow-medium);
        border-color: var(--color-brand-light);
      }

      .timeline-meta {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 1rem;
      }

      .timeline-meetup-tag {
        font-family: 'Fredoka', sans-serif;
        font-weight: 800;
        background: linear-gradient(135deg, var(--color-brand) 0%, var(--color-brand-dark) 100%);
        color: var(--color-text-white);
        padding: 4px 12px;
        font-size: 0.8rem;
        border-radius: 30px;
        letter-spacing: 0.05em;
      }

      .timeline-date {
        font-family: 'Fredoka', sans-serif;
        font-size: 0.95rem;
        font-weight: 700;
        color: var(--color-accent);
      }

      .timeline-title {
        font-size: 1.5rem;
        font-weight: 800;
        color: var(--color-text);
        margin-bottom: 1rem;
      }

      .timeline-desc {
        color: var(--color-text-muted);
        line-height: 1.8;
        font-size: 1rem;
        margin-bottom: 2rem;
      }

      /* Photo Gallery Layout inside Timeline */
      .timeline-gallery {
        display: grid;
        gap: 1.5rem;
      }

      .timeline-gallery.cols-1 {
        grid-template-columns: 1fr;
      }

      .timeline-gallery.cols-2 {
        grid-template-columns: 1fr 1fr;
      }

      .gallery-img-wrapper {
        position: relative;
        border-radius: var(--radius-sm);
        overflow: hidden;
        aspect-ratio: 16 / 10;
        border: 1px solid rgba(0, 0, 0, 0.06);
        cursor: pointer;
        box-shadow: var(--shadow-glass);
      }

      .gallery-img-wrapper img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: var(--transition-smooth);
      }

      .gallery-img-wrapper:hover img {
        transform: scale(1.04);
      }

      .gallery-img-overlay {
        position: absolute;
        top: 0; left: 0; right: 0; bottom: 0;
        background: rgba(0, 0, 0, 0);
        display: flex;
        align-items: center;
        justify-content: center;
        transition: var(--transition-fast);
        opacity: 0;
      }

      .gallery-img-wrapper:hover .gallery-img-overlay {
        background: rgba(0, 0, 0, 0.25);
        opacity: 1;
      }

      .overlay-icon {
        font-size: 1.8rem;
        color: var(--color-text-white);
        transform: scale(0.8);
        transition: var(--transition-smooth);
        text-shadow: 0 4px 10px rgba(0,0,0,0.3);
      }

      .gallery-img-wrapper:hover .overlay-icon {
        transform: scale(1);
      }

      /* Regular Events Section (Hidamari & Zundoko) */
      .events-container {
        max-width: 1100px;
        margin: 0 auto 6rem auto;
        padding: 0 1.5rem;
      }

      .events-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 2.5rem;
      }

      .event-card {
        background: var(--color-bg-glass);
        backdrop-filter: blur(10px);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-md);
        padding: 2.5rem;
        box-shadow: var(--shadow-glass);
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        transition: var(--transition-smooth);
      }

      .event-card:hover {
        transform: translateY(-4px);
        box-shadow: var(--shadow-medium);
        border-color: var(--color-brand-light);
      }

      .event-info h3 {
        font-size: 1.6rem;
        color: var(--color-brand-dark);
        margin-bottom: 0.5rem;
      }

      .event-badge {
        display: inline-block;
        background: var(--color-bg-secondary);
        color: var(--color-text-muted);
        font-size: 0.8rem;
        font-weight: 700;
        padding: 4px 12px;
        border-radius: 4px;
        margin-bottom: 1.25rem;
      }

      .event-desc {
        color: var(--color-text-muted);
        line-height: 1.8;
        font-size: 1rem;
        margin-bottom: 2rem;
      }

      /* CTA Box */
      .cta-box {
        background: linear-gradient(135deg, hsl(38, 25%, 93%) 0%, hsl(40, 40%, 98%) 100%);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-lg);
        padding: 4.5rem 2rem;
        text-align: center;
        max-width: 850px;
        margin: 6rem auto;
        box-shadow: var(--shadow-premium);
        position: relative;
        overflow: hidden;
      }

      .cta-box::before {
        content: "🐾";
        position: absolute;
        font-size: 8rem;
        opacity: 0.03;
        bottom: -2rem; right: -1rem;
        pointer-events: none;
      }

      .cta-box h3 {
        font-size: 2rem;
        color: var(--color-brand-dark);
        margin-bottom: 1.25rem;
      }

      .cta-box p {
        color: var(--color-text);
        margin-bottom: 2.5rem;
        max-width: 650px;
        margin: 0 auto 2.5rem auto;
        line-height: 1.8;
        font-size: 1.05rem;
      }

      /* Lightbox Component styles */
      .lightbox {
        position: fixed;
        top: 0; left: 0;
        width: 100vw; height: 100vh;
        background: rgba(18, 14, 10, 0.95);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        z-index: 1000;
        display: none;
        align-items: center;
        justify-content: center;
        opacity: 0;
        transition: opacity 0.35s ease;
      }

      .lightbox.active {
        display: flex;
        opacity: 1;
      }

      .lightbox-wrapper {
        position: relative;
        max-width: 90%;
        max-height: 85vh;
        display: flex;
        flex-direction: column;
        align-items: center;
      }

      .lightbox-img {
        max-width: 100%;
        max-height: 75vh;
        object-fit: contain;
        border-radius: var(--radius-sm);
        box-shadow: 0 20px 60px rgba(0,0,0,0.5);
        border: 2px solid rgba(255, 255, 255, 0.1);
        transform: scale(0.95);
        transition: transform 0.35s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.2s ease;
      }

      .lightbox.active .lightbox-img {
        transform: scale(1);
      }

      .lightbox-caption {
        color: var(--color-text-white);
        margin-top: 1.5rem;
        font-size: 1.1rem;
        font-weight: 700;
        text-align: center;
        max-width: 800px;
        line-height: 1.6;
        text-shadow: 0 2px 8px rgba(0,0,0,0.8);
        transition: opacity 0.2s ease;
      }

      .lightbox-btn {
        position: absolute;
        background: rgba(255, 255, 255, 0.1);
        color: var(--color-text-white);
        border: none;
        width: 3.5rem;
        height: 3.5rem;
        border-radius: 50%;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
        transition: var(--transition-fast);
        z-index: 1010;
        backdrop-filter: blur(4px);
      }

      .lightbox-btn:hover {
        background: var(--color-brand);
        color: var(--color-text-white);
        transform: scale(1.08);
      }

      .lightbox-prev {
        left: -5rem;
        top: 50%;
        transform: translateY(-50%);
      }

      .lightbox-next {
        right: -5rem;
        top: 50%;
        transform: translateY(-50%);
      }

      .lightbox-close {
        position: absolute;
        top: -4rem;
        right: 0;
        background: rgba(255, 255, 255, 0.15);
        color: var(--color-text-white);
        border: none;
        width: 3rem;
        height: 3rem;
        border-radius: 50%;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
        transition: var(--transition-fast);
        z-index: 1010;
      }

      .lightbox-close:hover {
        background: var(--color-accent);
        transform: rotate(90deg);
      }

      /* Responsive Adjustments */
      @media (max-width: 900px) {
        .intro-container {
          grid-template-columns: 1fr;
          gap: 3rem;
        }

        .events-grid {
          grid-template-columns: 1fr;
        }

        .timeline::before {
          left: 1.5rem;
        }

        .timeline-item {
          padding-left: 3.5rem;
        }

        .timeline-badge {
          left: 0.6rem;
        }

        .timeline-content {
          padding: 1.75rem;
        }

        .timeline-gallery.cols-2 {
          grid-template-columns: 1fr;
        }

        .lightbox-prev {
          left: 1rem;
          top: auto;
          bottom: -4.5rem;
          transform: none;
        }

        .lightbox-next {
          right: 1rem;
          top: auto;
          bottom: -4.5rem;
          transform: none;
        }

        .lightbox-close {
          right: 1rem;
          top: -3.5rem;
        }
      }
    </style>
  </head>
  <body>
    <Header />

    <!-- Page Hero -->
    <header class="page-hero">
      <div class="hero-badge brand-font">COMMUNITY</div>
      <h1>もふもふコミュニティ</h1>
      <p>フラットくんオーナーたちが紡ぎ出す、フレンドリーで親切な世界。<br/>初心者も大歓迎される、温かいふれあいの輪をご紹介します。</p>
    </header>

    <main>
      <!-- Intro Section -->
      <section class="intro-container">
        <div class="intro-text">
          <h2>みんなで作る、フラットくんの輪</h2>
          <p>
            オリジナルケモノアバター「フラット」には、非常にフレンドリーで活発なプレイヤーコミュニティが存在します。VRChatを始めたばかりで友達を見つけたい方や、同じアバターを持つ仲間とのんびり雑談を楽しみたい方にぴったりの居場所です。
          </p>
          <p>
            年に一度の定例集会では100名を超えるオーナーたちが大集合するほか、隔週開催の和風喫茶や、毎週金曜日のバーイベントなど、日常的に集まれる憩いのイベントが随時開催されています。
          </p>
        </div>

        <div class="stats-grid">
          <div class="stat-card">
            <div class="stat-num">200+</div>
            <div class="stat-label">公式グループメンバー</div>
          </div>
          <div class="stat-card">
            <div class="stat-num">100+</div>
            <div class="stat-label">最大集会参加人数</div>
          </div>
          <div class="stat-card">
            <div class="stat-num">9回+</div>
            <div class="stat-label">通算定例大集会</div>
          </div>
          <div class="stat-card">
            <div class="stat-num">100%</div>
            <div class="stat-label">もふもふ満足度</div>
          </div>
        </div>
      </section>

      <!-- Chronological Meetup History -->
      <section>
        <div class="section-title-wrapper">
          <h2>フラット集会ヒストリー 📷</h2>
          <p>第1回から第9回までの定例フラット集会。アバターの歴史とともに、少しずつ増えていった仲間の輪の歩みをお楽しみください。</p>
        </div>

        <div class="timeline">
          {meetups.map((meetup) => (
            <div class="timeline-item">
              <div class="timeline-badge"></div>
              <div class="timeline-content">
                <div class="timeline-meta">
                  <span class="timeline-meetup-tag">MEETUP #{meetup.num}</span>
                  <span class="timeline-date">{meetup.date}</span>
                </div>
                <h3 class="timeline-title">{meetup.title}</h3>
                <p class="timeline-desc">{meetup.desc}</p>
                
                <div class={`timeline-gallery cols-${meetup.images.length}`}>
                  {meetup.images.map((img, index) => (
                    <div 
                      class="gallery-img-wrapper gallery-img" 
                      data-src={`${currentBase}images/community/${img}`}
                      data-caption={`${meetup.title} — ${meetup.captions[index]}`}
                    >
                      <img 
                        src={`${currentBase}images/community/${img}`} 
                        alt={`${meetup.title}の集合写真`}
                        loading="lazy"
                      />
                      <div class="gallery-img-overlay">
                        <span class="overlay-icon">🔍</span>
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- Regular Activities Section -->
      <section>
        <div class="section-title-wrapper">
          <h2>日常の交流イベント 🐾</h2>
          <p>年に一度の大きな集会だけではありません。フラットオーナーやケモノ好きたちが気軽に集まり、雑談やロールプレイを楽しめる定期イベントです。</p>
        </div>

        <div class="events-container">
          <div class="events-grid">
            {regularEvents.map((event) => (
              <div class="event-card">
                <div class="event-info">
                  <h3>{event.title}</h3>
                  <span class="event-badge">{event.badge}</span>
                  <p class="event-desc">{event.desc}</p>
                </div>
                
                <div class={`timeline-gallery cols-${event.images.length}`} style="margin-top: 1.5rem;">
                  {event.images.map((img, index) => (
                    <div 
                      class="gallery-img-wrapper gallery-img" 
                      data-src={`${currentBase}images/community/${img}`}
                      data-caption={`${event.title} — ${event.captions[index]}`}
                    >
                      <img 
                        src={`${currentBase}images/community/${img}`} 
                        alt={`${event.title}の様子`}
                        loading="lazy"
                      />
                      <div class="gallery-img-overlay">
                        <span class="overlay-icon">🔍</span>
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- VRChat Group CTA -->
      <section class="cta-box">
        <h3>フラットオーナーズクラブに参加しよう！</h3>
        <p>
          VRChat公式グループ「Flat Owner's Club」に参加すると、突発的な集会、撮影会、定期イベントの開催告知などの情報を受け取ることができます。見学枠もありますので、まだアバターを購入していないファンの方もお気軽にご参加ください！
        </p>
        <a href="https://vrchat.com/home/group/grp_f15bceb1-874a-4458-a494-56ece83d0683" target="_blank" rel="noopener noreferrer" class="btn btn-accent btn-lg">
          VRChatグループページを開く 🐾
        </a>
      </section>
    </main>

    <!-- Lightbox Modal -->
    <div id="lightbox" class="lightbox" role="dialog" aria-modal="true" aria-label="画像拡大ビュー">
      <button class="lightbox-close" id="lightbox-close" aria-label="閉じる">✕</button>
      <button class="lightbox-btn lightbox-prev" id="lightbox-prev" aria-label="前の画像">◀</button>
      
      <div class="lightbox-wrapper">
        <img id="lightbox-img" class="lightbox-img" src="" alt="拡大画像" />
        <p id="lightbox-caption" class="lightbox-caption"></p>
      </div>

      <button class="lightbox-btn lightbox-next" id="lightbox-next" aria-label="次の画像">▶</button>
    </div>

    <!-- Lightbox Client Script -->
    <script>
      // Wait for DOM to load
      document.addEventListener('DOMContentLoaded', () => {
        const lightbox = document.getElementById('lightbox');
        const lightboxImg = document.getElementById('lightbox-img');
        const lightboxCaption = document.getElementById('lightbox-caption');
        const closeBtn = document.getElementById('lightbox-close');
        const prevBtn = document.getElementById('lightbox-prev');
        const nextBtn = document.getElementById('lightbox-next');
        
        // Find all clickable gallery items
        const galleryItems = Array.from(document.querySelectorAll('.gallery-img'));
        let currentIndex = -1;

        if (!lightbox || !lightboxImg || !lightboxCaption || !closeBtn || !prevBtn || !nextBtn) return;

        // Show image in lightbox
        function showImage(index) {
          if (index < 0 || index >= galleryItems.length) return;
          currentIndex = index;
          
          const item = galleryItems[index];
          const src = item.getAttribute('data-src') || '';
          const caption = item.getAttribute('data-caption') || '';
          
          // Smooth crossfade using opacity transition
          lightboxImg.style.opacity = '0';
          lightboxCaption.style.opacity = '0';
          
          setTimeout(() => {
            lightboxImg.src = src;
            lightboxCaption.textContent = caption;
            
            // Wait for image to load before fading back in
            lightboxImg.onload = () => {
              lightboxImg.style.opacity = '1';
              lightboxCaption.style.opacity = '1';
            };
          }, 150);
        }

        // Open Lightbox
        galleryItems.forEach((item, index) => {
          item.addEventListener('click', () => {
            lightbox.classList.add('active');
            document.body.style.overflow = 'hidden'; // Disable page scrolling
            showImage(index);
          });
        });

        // Close Lightbox
        function closeLightbox() {
          lightbox.classList.remove('active');
          document.body.style.overflow = ''; // Re-enable page scrolling
        }

        closeBtn.addEventListener('click', closeLightbox);
        
        // Click background to close
        lightbox.addEventListener('click', (e) => {
          if (e.target === lightbox) {
            closeLightbox();
          }
        });

        // Navigate Next / Prev
        function showNext() {
          let nextIndex = currentIndex + 1;
          if (nextIndex >= galleryItems.length) nextIndex = 0;
          showImage(nextIndex);
        }

        function showPrev() {
          let prevIndex = currentIndex - 1;
          if (prevIndex < 0) prevIndex = galleryItems.length - 1;
          showImage(prevIndex);
        }

        nextBtn.addEventListener('click', showNext);
        prevBtn.addEventListener('click', showPrev);

        // Keyboard navigation
        document.addEventListener('keydown', (e) => {
          if (!lightbox.classList.contains('active')) return;
          
          if (e.key === 'Escape') {
            closeLightbox();
          } else if (e.key === 'ArrowRight') {
            showNext();
          } else if (e.key === 'ArrowLeft') {
            showPrev();
          }
        });
      });
    </script>

    <Footer />
  </body>
</html>
