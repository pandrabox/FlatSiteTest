---
// src/pages/community.astro
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const currentBase = import.meta.env.BASE_URL;

const SEO_TITLE = "フラットくんの温かいコミュニティ | フラットファンクラブ";
const SEO_DESCRIPTION = "アバター「フラット」くんのオーナーたちが集まる、愛にあふれたコミュニティの紹介。年1回100名以上が集まる大集会や、日々の交流情報をお届け！";
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <BaseHead title={SEO_TITLE} description={SEO_DESCRIPTION} />
    <style>
      .page-hero {
        background: linear-gradient(135deg, hsl(37, 95%, 72%) 0%, hsl(30, 85%, 45%) 100%);
        color: var(--color-text-white);
        padding: 5rem 1.5rem;
        text-align: center;
        border-radius: 0 0 var(--radius-lg) var(--radius-lg);
      }

      .page-hero h1 {
        font-size: clamp(2rem, 5vw, 3.2rem);
        color: var(--color-text-white);
        margin-bottom: 1rem;
        font-weight: 900;
        text-shadow: 0 4px 10px rgba(0,0,0,0.1);
      }

      .page-hero p {
        font-size: clamp(0.95rem, 2vw, 1.15rem);
        color: rgba(255, 255, 255, 0.9);
        max-width: 600px;
        margin: 0 auto;
      }

      .content-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 3rem;
        margin: 4rem auto;
        max-width: 1200px;
        padding: 0 1.5rem;
      }

      .stats-panel {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 1.5rem;
      }

      .stat-card {
        background: var(--color-bg-glass);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-md);
        padding: 2rem;
        text-align: center;
        box-shadow: var(--shadow-glass);
      }

      .stat-num {
        font-family: 'Fredoka', sans-serif;
        font-size: 2.8rem;
        font-weight: 800;
        color: var(--color-brand-dark);
        line-height: 1;
        margin-bottom: 8px;
      }

      .stat-label {
        font-size: 0.9rem;
        color: var(--color-text-muted);
        font-weight: 700;
      }

      .gallery-section {
        max-width: 1200px;
        margin: 6rem auto;
        padding: 0 1.5rem;
      }

      .gallery-grid {
        display: grid;
        grid-template-columns: 2fr 1fr 1fr;
        gap: 1.5rem;
        margin-top: 2.5rem;
      }

      .gallery-item {
        position: relative;
        border-radius: var(--radius-md);
        overflow: hidden;
        aspect-ratio: 1.5;
        box-shadow: var(--shadow-medium);
        border: 1px solid var(--color-border);
      }

      .gallery-item.large {
        grid-row: span 2;
        aspect-ratio: 1.2;
      }

      .gallery-item img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: var(--transition-smooth);
      }

      .gallery-item:hover img {
        transform: scale(1.04);
      }

      .gallery-caption {
        position: absolute;
        bottom: 0; left: 0; right: 0;
        background: linear-gradient(to top, rgba(0,0,0,0.8) 0%, rgba(0,0,0,0) 100%);
        color: var(--color-text-white);
        padding: 1.5rem;
        font-size: 0.95rem;
        font-weight: 700;
      }

      .cta-box {
        background: linear-gradient(135deg, hsl(38, 25%, 93%) 0%, hsl(40, 40%, 98%) 100%);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-lg);
        padding: 4rem 2rem;
        text-align: center;
        max-width: 800px;
        margin: 4rem auto;
        box-shadow: var(--shadow-glass);
      }

      .cta-box h3 {
        font-size: 1.8rem;
        color: var(--color-brand-dark);
        margin-bottom: 1rem;
      }

      .cta-box p {
        color: var(--color-text-muted);
        margin-bottom: 2rem;
        max-width: 600px;
        margin: 0 auto 2rem auto;
      }

      @media (max-width: 900px) {
        .content-grid {
          grid-template-columns: 1fr;
          gap: 2rem;
        }

        .gallery-grid {
          grid-template-columns: 1fr;
          gap: 1rem;
        }

        .gallery-item.large {
          grid-row: span 1;
          aspect-ratio: 1.5;
        }
      }
    </style>
  </head>
  <body>
    <Header />

    <!-- Page Hero -->
    <header class="page-hero">
      <h1>あたたかいコミュニティ</h1>
      <p>フラットくんオーナーたちは非常にフレンドリーで親切！<br/>初心者の方もいつでも大歓迎される、もふもふフレンドの輪をご紹介します。</p>
    </header>

    <!-- Info Sections -->
    <main class="content-grid">
      <div style="display: flex; flex-direction: column; justify-content: center; gap: 1.5rem;">
        <h2 style="font-size: 1.8rem; color: var(--color-brand-dark);">
          みんなで作る、フラットくんの輪 💛
        </h2>
        <p style="color: var(--color-text); line-height: 1.8;">
          アバター「フラット」には、公式・非公式のプレイヤーグループが存在し、日々温かい交流が行われています。VRChatを始めたばかりで友達がいない方や、ケモノアバター同士でまったりお喋りしたい方にぴったりの居場所です。
        </p>
        <p style="color: var(--color-text-muted); line-height: 1.8; font-size: 0.95rem;">
          年1回の公式・有志の「大定例集会」の他にも、不定期の週末にカフェワールドに集まったり、Twitter（X）で「#フラットくん」のハッシュタグを使って日々の可愛いお写真やアバター改変の進捗を共有しあう優しい文化があります。
        </p>
      </div>

      <!-- Stats Cards -->
      <div class="stats-panel">
        <div class="stat-card">
          <div class="stat-num">211+</div>
          <div class="stat-label">グループ参加メンバー数</div>
        </div>
        <div class="stat-card">
          <div class="stat-num">100+</div>
          <div class="stat-label">定例集会最大参加人数</div>
        </div>
        <div class="stat-card">
          <div class="stat-num">1回 / 年</div>
          <div class="stat-label">定例大集会開催頻度</div>
        </div>
        <div class="stat-card">
          <div class="stat-num">20+</div>
          <div class="stat-label">ファンメイド衣装配布数</div>
        </div>
      </div>
    </main>

    <!-- Photo Gallery -->
    <section class="gallery-section">
      <div style="text-align: center; margin-bottom: 2rem;">
        <h2 style="font-size: 1.8rem; color: var(--color-text);">思い出ギャラリー 📷</h2>
        <p style="color: var(--color-text-muted);">大集会や不定期の集まりなど、もふもふたちの楽しそうな日常の一コマ。</p>
      </div>

      <div class="gallery-grid">
        <!-- Large Item -->
        <div class="gallery-item large">
          <img src={`${currentBase}images/Meetup.webp`} alt="100人以上のフラットくんオーナーが集まった大集会記念撮影画像" />
          <div class="gallery-caption">圧巻！年に一度のフラット定例集会での大集合写真。黄色の可愛さで埋め尽くされます！</div>
        </div>

        <!-- Medium Item 1 -->
        <div class="gallery-item">
          <img src={`${currentBase}images/FirstViewPC.webp`} alt="VRChat内での笑顔のフラットくんたちの日常写真" />
          <div class="gallery-caption">お友達と一緒にピース！</div>
        </div>

        <!-- Medium Item 2 -->
        <div class="gallery-item">
          <img src={`${currentBase}images/Welcome.webp`} alt="歓迎ワールドでのフラットくんのイメージ写真" />
          <div class="gallery-caption">いつでも温かく歓迎します！</div>
        </div>
      </div>
    </section>

    <!-- Group Invite CTA -->
    <section class="cta-box">
      <h3>フラットグループに参加しよう！</h3>
      <p>VRChatの公式グループ「Flat Owner's Club」に参加すると、イベント情報や突発的な撮影会のお知らせを受け取ることができます。見学枠もありますので、まだ購入していない方もお気軽にどうぞ！</p>
      <a href="https://vrchat.com/home/group/grp_e8f23456-7890-abcd-ef01-234567890123" target="_blank" rel="noopener noreferrer" class="btn btn-accent btn-lg">
        VRChatグループページを開く 🐾
      </a>
    </section>

    <Footer />
  </body>
</html>
