---
// src/pages/items.astro
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';

const currentBase = import.meta.env.BASE_URL + '/';

// Get all booth items (only files with numeric names)
const allItems = await getCollection('boothItems');

// カテゴリ定義
const CATEGORIES = [
  { key: 'avatar', label: 'アバター' },
  { key: 'cloth', label: '衣装' },
  { key: 'accessory', label: 'アクセサリ' },
  { key: 'cosmetic', label: 'コスメ' },
  { key: 'tool', label: 'ツール' },
  { key: 'other', label: 'その他' },
];

// Helper function to determine filter category from tags
function getFilterCategory(tags: string): string {
  const tagLower = tags.toLowerCase();
  if (tagLower.includes('cloth')) return 'cloth';
  if (tagLower.includes('tool')) return 'tool';
  if (tagLower.includes('accessory')) return 'accessory';
  if (tagLower.includes('cosmetic')) return 'cosmetic';
  if (tagLower.includes('avatar')) return 'avatar';
  if (tagLower.includes('other')) return 'other';
  return 'other';
}

// Helper function to get category label from tags
function getCategoryLabel(tags: string): string {
  const cat = getFilterCategory(tags);
  const def = CATEGORIES.find(c => c.key === cat);
  return def ? def.label : 'その他';
}

// Helper function to check if official
function isOfficial(tags: string): boolean {
  return tags.toLowerCase().includes('official');
}

// アイテムをカテゴリ別にグループ化し、Official優先・商品番号降順にソート
function groupAndSortItems(items: typeof allItems) {
  const groups: Record<string, typeof items> = {};
  
  for (const item of items) {
    const cat = getFilterCategory(item.data.Tag);
    if (!groups[cat]) groups[cat] = [];
    groups[cat].push(item);
  }
  
  // 各カテゴリ内で Official を先頭に、その後は boothId 降順
  for (const cat in groups) {
    groups[cat].sort((a, b) => {
      const aOff = isOfficial(a.data.Tag) ? 1 : 0;
      const bOff = isOfficial(b.data.Tag) ? 1 : 0;
      if (aOff !== bOff) return bOff - aOff; // Official を先頭に
      return b.data.boothId - a.data.boothId; // boothId 降順
    });
  }
  
  return groups;
}

const groupedItems = groupAndSortItems(allItems);

const SEO_TITLE = "衣装・カスタムアセット カタログ | フラットファンクラブ";
const SEO_DESCRIPTION = "アバター「フラット」くんの公式バリエーション、ファンメイドの可愛いお洋服、しっぽ揺れやお腹もちもちのコミュニケーション拡張ギミックのBoothリンクカタログ！";
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <BaseHead title={SEO_TITLE} description={SEO_DESCRIPTION} />
    <style>
      .page-hero {
        background: linear-gradient(135deg, hsl(37, 95%, 72%) 0%, hsl(30, 85%, 45%) 100%);
        color: var(--color-text-white);
        padding: 5rem 1.5rem;
        text-align: center;
        border-radius: 0 0 var(--radius-lg) var(--radius-lg);
      }

      .page-hero h1 {
        font-size: clamp(2rem, 5vw, 3.2rem);
        color: var(--color-text-white);
        margin-bottom: 1rem;
        font-weight: 900;
        text-shadow: 0 4px 10px rgba(0,0,0,0.1);
      }

      .page-hero p {
        font-size: clamp(0.95rem, 2vw, 1.15rem);
        color: rgba(255, 255, 255, 0.9);
        max-width: 600px;
        margin: 0 auto;
      }

      .catalog-container {
        max-width: 1200px;
        margin: 4rem auto;
        padding: 0 1.5rem;
      }

      /* Filter Tabs */
      .filter-tabs {
        display: flex;
        justify-content: center;
        gap: 1rem;
        flex-wrap: wrap;
        margin-bottom: 3rem;
      }

      .tab-btn {
        background: var(--color-bg-glass);
        border: 2px solid var(--color-border);
        color: var(--color-text);
        padding: 10px 24px;
        border-radius: 30px;
        font-weight: 700;
        cursor: pointer;
        transition: var(--transition-smooth);
        font-size: 0.95rem;
      }

      .tab-btn:hover {
        border-color: var(--color-brand-light);
        background: rgba(244, 173, 57, 0.08);
      }

      .tab-btn.active {
        background: var(--color-brand);
        color: var(--color-text-white);
        border-color: var(--color-brand);
        box-shadow: var(--shadow-soft);
      }

      /* Catalog Grid */
      .catalog-grid {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        gap: 1.5rem;
      }

      @media (max-width: 1200px) {
        .catalog-grid {
          grid-template-columns: repeat(4, 1fr);
        }
      }

      @media (max-width: 900px) {
        .catalog-grid {
          grid-template-columns: repeat(3, 1fr);
        }
      }

      @media (max-width: 600px) {
        .catalog-grid {
          grid-template-columns: repeat(2, 1fr);
          gap: 1rem;
        }
      }

      /* Category Section */
      .category-section {
        margin-bottom: 3rem;
      }

      .category-header {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 1.5rem;
        padding-bottom: 0.5rem;
        border-bottom: 2px solid var(--color-brand);
      }

      .category-header h2 {
        font-size: 1.5rem;
        font-weight: 800;
        color: var(--color-text);
      }

      .category-count {
        font-size: 0.85rem;
        color: var(--color-text-muted);
        background: var(--color-bg-glass);
        padding: 2px 10px;
        border-radius: 12px;
      }

      .catalog-card {
        background: var(--color-bg-glass);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-lg);
        overflow: hidden;
        box-shadow: var(--shadow-glass);
        transition: var(--transition-smooth);
        display: flex;
        flex-direction: column;
      }

      .catalog-card:hover {
        transform: translateY(-8px);
        box-shadow: var(--shadow-premium);
        border-color: var(--color-brand);
      }

      .catalog-img-wrapper {
        position: relative;
        aspect-ratio: 1.1;
        background-color: var(--color-bg-secondary);
        overflow: hidden;
        border-bottom: 1px solid var(--color-border);
      }

      .catalog-img-wrapper img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: var(--transition-smooth);
      }

      .catalog-card:hover .catalog-img-wrapper img {
        transform: scale(1.05);
      }

      .category-badge {
        position: absolute;
        top: 12px;
        left: 12px;
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(8px);
        color: var(--color-brand-dark);
        font-size: 0.75rem;
        font-weight: 800;
        padding: 4px 12px;
        border-radius: 30px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.05);
        border: 1px solid rgba(244, 173, 57, 0.2);
      }

      .author-type-badge {
        position: absolute;
        top: 12px;
        right: 12px;
        background: rgba(244, 173, 57, 0.9);
        backdrop-filter: blur(8px);
        color: white;
        font-size: 0.75rem;
        font-weight: 800;
        padding: 4px 12px;
        border-radius: 30px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.05);
      }

      .author-type-badge.fanmade {
        background: rgba(100, 100, 255, 0.9);
      }

      .catalog-info {
        padding: 1rem;
        display: flex;
        flex-direction: column;
        flex-grow: 1;
        gap: 0.6rem;
      }

      .catalog-title {
        font-size: 1rem !important;
        font-weight: 800;
        line-height: 1.3;
      }

      .catalog-footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: auto;
      }

      .catalog-price {
        font-family: 'Fredoka', sans-serif;
        font-size: 1.1rem;
        font-weight: 700;
        color: var(--color-accent);
      }

      .catalog-btn {
        font-size: 0.8rem;
        padding: 6px 14px;
        margin-top: 0;
      }

      /* Empty State */
      .catalog-empty {
        display: none;
        text-align: center;
        padding: 5rem 2rem;
        color: var(--color-text-muted);
        font-size: 1.1rem;
      }

      @media (max-width: 600px) {
        .filter-tabs {
          gap: 0.5rem;
        }

        .tab-btn {
          padding: 8px 16px;
          font-size: 0.85rem;
        }
      }
    </style>
  </head>
  <body>
    <Header />

    <!-- Page Hero -->
    <header class="page-hero">
      <h1>衣装・カスタムアイテム</h1>
      <p>公式アバター、オシャレなファンメイドの洋服、<br/>もふもふコミュニケーションをもっと楽しむギミックの厳選Boothカタログです！</p>
    </header>

    <!-- Catalog Main Area -->
    <main class="catalog-container">
      
      <!-- Category Grouped Catalog -->
      {CATEGORIES.map((cat) => {
        const items = groupedItems[cat.key];
        if (!items || items.length === 0) return null;

        return (
          <section class="category-section" id={`cat-${cat.key}`}>
            <div class="category-header">
              <h2>{cat.label}</h2>
              <span class="category-count">{items.length} 件</span>
            </div>
            <div class="catalog-grid">
              {items.map((item) => {
                const boothUrl = `https://booth.pm/ja/items/${item.data.boothId}`;
                const imageUrl = `${currentBase}images/booth/${item.data.boothId}.webp`;
                const official = isOfficial(item.data.Tag);

                return (
                  <article class="catalog-card" data-category={cat.key}>
                    <div class="catalog-img-wrapper">
                      <img src={imageUrl} alt={`${item.data.title} の商品紹介イメージ画像`} />
                      <span class="category-badge">{cat.label.split(' ')[0]}</span>
                      {official ? <span class="author-type-badge">公式</span> : <span class="author-type-badge fanmade">ファンメイド</span>}
                    </div>
                    <div class="catalog-info">
                      <h3 class="catalog-title">{item.data.title}</h3>
                      <div class="catalog-footer">
                        <span class="catalog-price">{item.data.price === 0 ? '無料' : `¥${item.data.price.toLocaleString()}`}</span>
                        <a href={boothUrl} target="_blank" rel="noopener noreferrer" class="btn btn-primary catalog-btn">
                          Booth
                        </a>
                      </div>
                    </div>
                  </article>
                );
              })}
            </div>
          </section>
        );
      })}

    </main>

    <Footer />
  </body>
</html>
