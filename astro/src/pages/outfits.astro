---
// src/pages/outfits.astro
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';

const currentBase = import.meta.env.BASE_URL;

// Get all booth items
const allItems = await getCollection('boothItems');

// Sort items: Avatars first, then rank
const sortedItems = allItems.sort((a, b) => {
  if (a.data.category === 'avatar' && b.data.category !== 'avatar') return -1;
  if (a.data.category !== 'avatar' && b.data.category === 'avatar') return 1;
  return b.data.recommendRank - a.data.recommendRank;
});

const SEO_TITLE = "衣装・カスタムアセット カタログ | フラットファンクラブ";
const SEO_DESCRIPTION = "アバター「フラット」くんの公式バリエーション、ファンメイドの可愛いお洋服、しっぽ揺れやお腹もちもちのコミュニケーション拡張ギミックのBoothリンクカタログ！";
---

<!DOCTYPE html>
<html lang="ja">
  <head>
    <BaseHead title={SEO_TITLE} description={SEO_DESCRIPTION} />
    <style>
      .page-hero {
        background: linear-gradient(135deg, hsl(37, 95%, 72%) 0%, hsl(30, 85%, 45%) 100%);
        color: var(--color-text-white);
        padding: 5rem 1.5rem;
        text-align: center;
        border-radius: 0 0 var(--radius-lg) var(--radius-lg);
      }

      .page-hero h1 {
        font-size: clamp(2rem, 5vw, 3.2rem);
        color: var(--color-text-white);
        margin-bottom: 1rem;
        font-weight: 900;
        text-shadow: 0 4px 10px rgba(0,0,0,0.1);
      }

      .page-hero p {
        font-size: clamp(0.95rem, 2vw, 1.15rem);
        color: rgba(255, 255, 255, 0.9);
        max-width: 600px;
        margin: 0 auto;
      }

      .catalog-container {
        max-width: 1200px;
        margin: 4rem auto;
        padding: 0 1.5rem;
      }

      /* Filter Tabs */
      .filter-tabs {
        display: flex;
        justify-content: center;
        gap: 1rem;
        flex-wrap: wrap;
        margin-bottom: 3rem;
      }

      .tab-btn {
        background: var(--color-bg-glass);
        border: 2px solid var(--color-border);
        color: var(--color-text);
        padding: 10px 24px;
        border-radius: 30px;
        font-weight: 700;
        cursor: pointer;
        transition: var(--transition-smooth);
        font-size: 0.95rem;
      }

      .tab-btn:hover {
        border-color: var(--color-brand-light);
        background: rgba(244, 173, 57, 0.08);
      }

      .tab-btn.active {
        background: var(--color-brand);
        color: var(--color-text-white);
        border-color: var(--color-brand);
        box-shadow: var(--shadow-soft);
      }

      /* Catalog Grid */
      .catalog-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 2.5rem;
      }

      .catalog-card {
        background: var(--color-bg-glass);
        border: 1px solid var(--color-border);
        border-radius: var(--radius-lg);
        overflow: hidden;
        box-shadow: var(--shadow-glass);
        transition: var(--transition-smooth);
        display: flex;
        flex-direction: column;
      }

      .catalog-card:hover {
        transform: translateY(-8px);
        box-shadow: var(--shadow-premium);
        border-color: var(--color-brand);
      }

      .catalog-img-wrapper {
        position: relative;
        aspect-ratio: 1.1;
        background-color: var(--color-bg-secondary);
        overflow: hidden;
        border-bottom: 1px solid var(--color-border);
      }

      .catalog-img-wrapper img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: var(--transition-smooth);
      }

      .catalog-card:hover .catalog-img-wrapper img {
        transform: scale(1.05);
      }

      .category-badge {
        position: absolute;
        top: 12px;
        left: 12px;
        background: rgba(255, 255, 255, 0.9);
        backdrop-filter: blur(8px);
        color: var(--color-brand-dark);
        font-size: 0.75rem;
        font-weight: 800;
        padding: 4px 12px;
        border-radius: 30px;
        box-shadow: 0 4px 10px rgba(0,0,0,0.05);
        border: 1px solid rgba(244, 173, 57, 0.2);
      }

      .catalog-info {
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        flex-grow: 1;
        gap: 0.8rem;
      }

      .catalog-info h3 {
        font-size: 1.2rem;
        font-weight: 800;
        line-height: 1.4;
      }

      .catalog-author {
        font-size: 0.8rem;
        color: var(--color-text-muted);
        font-weight: 700;
      }

      .catalog-price {
        font-family: 'Fredoka', sans-serif;
        font-size: 1.4rem;
        font-weight: 700;
        color: var(--color-accent);
      }

      .catalog-desc {
        font-size: 0.85rem;
        color: var(--color-text-muted);
        line-height: 1.6;
        flex-grow: 1;
      }

      .catalog-stars {
        display: flex;
        gap: 2px;
        color: #FFD700;
        font-size: 0.85rem;
      }

      .catalog-btn {
        margin-top: 1rem;
        font-size: 0.9rem;
        padding: 10px 20px;
      }

      /* Empty State */
      .catalog-empty {
        display: none;
        text-align: center;
        padding: 5rem 2rem;
        color: var(--color-text-muted);
        font-size: 1.1rem;
      }

      @media (max-width: 600px) {
        .filter-tabs {
          gap: 0.5rem;
        }

        .tab-btn {
          padding: 8px 16px;
          font-size: 0.85rem;
        }
      }
    </style>
  </head>
  <body>
    <Header />

    <!-- Page Hero -->
    <header class="page-hero">
      <h1>衣装・カスタムアイテム</h1>
      <p>公式アバター、オシャレなファンメイドの洋服、<br/>もふもふコミュニケーションをもっと楽しむギミックの厳選Boothカタログです！</p>
    </header>

    <!-- Catalog Main Area -->
    <main class="catalog-container">
      
      <!-- Filter Tabs -->
      <div class="filter-tabs">
        <button class="tab-btn active" data-filter="all">すべて ✨</button>
        <button class="tab-btn" data-filter="avatar">アバター 🐾</button>
        <button class="tab-btn" data-filter="clothing">衣装・アウター 👗</button>
        <button class="tab-btn" data-filter="gimmick">拡張ギミック ⚙️</button>
      </div>

      <!-- Catalog Grid -->
      <div class="catalog-grid" id="catalogGrid">
        {sortedItems.map((item) => {
          // Determine friendly category name
          let categoryLabel = "アセット";
          let filterCategory = "other";
          if (item.data.category === 'avatar') {
            categoryLabel = "アバター本体";
            filterCategory = "avatar";
          } else if (item.data.category === 'official_clothing' || item.data.category === 'fan_clothing') {
            categoryLabel = "衣装";
            filterCategory = "clothing";
          } else if (item.data.category === 'gimmick') {
            categoryLabel = "ギミック";
            filterCategory = "gimmick";
          }

          // Build stars array
          const stars = Array.from({ length: 5 }, (_, i) => i < item.data.recommendRank ? "⭐" : "☆").join("");

          return (
            <article class="catalog-card" data-category={filterCategory}>
              <div class="catalog-img-wrapper">
                <img src={`${currentBase}images/${item.data.imageUrl}`} alt={`${item.data.title} の商品紹介イメージ画像`} />
                <span class="category-badge">{categoryLabel}</span>
              </div>
              <div class="catalog-info">
                <div class="catalog-stars">{stars}</div>
                <h3>{item.data.title}</h3>
                <span class="catalog-author">製作者: {item.data.author}</span>
                <p class="catalog-desc">{item.data.description}</p>
                <div class="catalog-price">¥{item.data.price.toLocaleString()}</div>
                <a href={item.data.boothUrl} target="_blank" rel="noopener noreferrer" class="btn btn-primary catalog-btn">
                  Boothで購入する 🛒
                </a>
              </div>
            </article>
          );
        })}
      </div>

      <!-- Empty State Warning -->
      <div class="catalog-empty" id="catalogEmpty">
        <p>該当するアイテムが見つかりませんでした。🐾</p>
      </div>

    </main>

    <Footer />

    <script>
      // Filter Logic
      const tabs = document.querySelectorAll('.tab-btn');
      const cards = document.querySelectorAll('.catalog-card');
      const emptyState = document.getElementById('catalogEmpty');

      if (tabs && cards) {
        tabs.forEach(tab => {
          tab.addEventListener('click', () => {
            // Remove active from all tabs
            tabs.forEach(t => t.classList.remove('active'));
            // Add active to current tab
            tab.classList.add('active');

            const filterValue = tab.getAttribute('data-filter');
            let visibleCount = 0;

            cards.forEach(card => {
              const category = card.getAttribute('data-category');
              if (filterValue === 'all' || category === filterValue) {
                (card as HTMLElement).style.display = 'flex';
                visibleCount++;
              } else {
                (card as HTMLElement).style.display = 'none';
              }
            });

            // Handle empty state
            if (emptyState) {
              if (visibleCount === 0) {
                emptyState.style.display = 'block';
              } else {
                emptyState.style.display = 'none';
              }
            }
          });
        });
      }
    </script>
  </body>
</html>
