---
// src/components/Header.astro
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header class="header">
  <nav class="nav-container">
    <div class="nav-brand">
      <a href={`${import.meta.env.BASE_URL}`} class="brand-link brand-font">
        <span class="brand-icon">🐾</span> {SITE_TITLE}
      </a>
    </div>
    
    <!-- Desktop Navigation -->
    <div class="nav-links desktop-only">
      <HeaderLink href={`${import.meta.env.BASE_URL}`} class="nav-item">ホーム</HeaderLink>
      <HeaderLink href={`${import.meta.env.BASE_URL}guide/`} class="nav-item">入門ガイド</HeaderLink>
      <HeaderLink href={`${import.meta.env.BASE_URL}community/`} class="nav-item">コミュニティ</HeaderLink>
      <HeaderLink href={`${import.meta.env.BASE_URL}outfits/`} class="nav-item">衣装・カスタム</HeaderLink>
      <HeaderLink href={`${import.meta.env.BASE_URL}history/`} class="nav-item">歴史</HeaderLink>
    </div>

    <div class="nav-actions desktop-only">
      <a href="https://booth.pm/ja/search/%E3%83%95%E3%83%A9%E3%83%83%E3%83%88" target="_blank" rel="noopener noreferrer" class="btn btn-accent btn-sm header-cta">
        Boothでフラットを探す 🛒
      </a>
    </div>

    <!-- Mobile Menu Button -->
    <button class="mobile-menu-toggle mobile-only" aria-label="メニューを開閉する" id="menuToggle">
      <span class="bar"></span>
      <span class="bar"></span>
      <span class="bar"></span>
    </button>
  </nav>

  <!-- Mobile Dropdown Navigation -->
  <div class="mobile-menu mobile-only" id="mobileMenu">
    <div class="mobile-menu-inner">
      <HeaderLink href={`${import.meta.env.BASE_URL}`} class="mobile-nav-item">ホーム</HeaderLink>
      <HeaderLink href={`${import.meta.env.BASE_URL}guide/`} class="mobile-nav-item">入門ガイド</HeaderLink>
      <HeaderLink href={`${import.meta.env.BASE_URL}community/`} class="mobile-nav-item">コミュニティ</HeaderLink>
      <HeaderLink href={`${import.meta.env.BASE_URL}outfits/`} class="mobile-nav-item">衣装・カスタム</HeaderLink>
      <HeaderLink href={`${import.meta.env.BASE_URL}history/`} class="mobile-nav-item">歴史</HeaderLink>
      
      <div class="mobile-menu-footer">
        <a href="https://booth.pm/ja/search/%E3%83%95%E3%83%A9%E3%83%83%E3%83%88" target="_blank" rel="noopener noreferrer" class="btn btn-accent btn-block">
          Boothでフラットを探す 🛒
        </a>
      </div>
    </div>
  </div>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 1000;
    background: rgba(253, 251, 247, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(244, 173, 57, 0.15);
    box-shadow: 0 4px 20px rgba(244, 173, 57, 0.05);
    height: 70px;
    display: flex;
    align-items: center;
  }

  .nav-container {
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-brand .brand-link {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 1.35rem;
    font-weight: 800;
    color: var(--color-text);
    text-decoration: none;
    transition: var(--transition-fast);
  }

  .nav-brand .brand-link:hover {
    color: var(--color-brand-dark);
  }

  .brand-icon {
    font-size: 1.5rem;
    filter: drop-shadow(0 2px 4px rgba(244, 173, 57, 0.2));
  }

  .nav-links {
    display: flex;
    gap: 1.5rem;
  }

  .nav-item {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-text-muted);
    padding: 8px 16px;
    border-radius: 20px;
    transition: var(--transition-fast);
    text-decoration: none;
    border-bottom: 2px solid transparent;
  }

  .nav-item:hover, .nav-item.active {
    color: var(--color-brand-dark);
    background-color: rgba(244, 173, 57, 0.08);
  }

  .nav-actions {
    display: flex;
    align-items: center;
  }

  .header-cta {
    padding: 8px 20px;
    font-size: 0.85rem;
  }

  /* Hamburger Menu Button */
  .mobile-menu-toggle {
    background: transparent;
    border: none;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    width: 24px;
    height: 18px;
    padding: 0;
    z-index: 1001;
  }

  .mobile-menu-toggle .bar {
    width: 100%;
    height: 3px;
    background-color: var(--color-text);
    border-radius: 2px;
    transition: var(--transition-fast);
  }

  .mobile-menu-toggle.open .bar:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
    background-color: var(--color-accent);
  }

  .mobile-menu-toggle.open .bar:nth-child(2) {
    opacity: 0;
  }

  .mobile-menu-toggle.open .bar:nth-child(3) {
    transform: translateY(-8px) rotate(-45deg);
    background-color: var(--color-accent);
  }

  /* Mobile Dropdown Menu */
  .mobile-menu {
    position: fixed;
    top: 70px;
    left: 0;
    right: 0;
    background: var(--color-bg);
    border-bottom: 2px solid var(--color-brand-light);
    box-shadow: var(--shadow-medium);
    opacity: 0;
    visibility: hidden;
    transform: translateY(-10px);
    transition: var(--transition-smooth);
    z-index: 999;
  }

  .mobile-menu.open {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .mobile-menu-inner {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .mobile-nav-item {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-text);
    padding: 12px 16px;
    border-radius: var(--radius-sm);
    text-decoration: none;
    transition: var(--transition-fast);
    background-color: var(--color-bg-secondary);
  }

  .mobile-nav-item:hover, .mobile-nav-item.active {
    color: var(--color-text-white);
    background-color: var(--color-brand);
  }

  .mobile-menu-footer {
    margin-top: 1rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
  }

  .btn-block {
    width: 100%;
    text-align: center;
  }

  /* Responsive Display Utilities */
  .desktop-only {
    display: flex;
  }

  .mobile-only {
    display: none;
  }

  @media (max-width: 900px) {
    .desktop-only {
      display: none;
    }

    .mobile-only {
      display: flex;
    }
  }
</style>

<script>
  const menuToggle = document.getElementById('menuToggle');
  const mobileMenu = document.getElementById('mobileMenu');

  if (menuToggle && mobileMenu) {
    menuToggle.addEventListener('click', () => {
      menuToggle.classList.toggle('open');
      mobileMenu.classList.toggle('open');
    });

    // Close menu when clicking navigation items
    const mobileNavItems = mobileMenu.querySelectorAll('.mobile-nav-item');
    mobileNavItems.forEach(item => {
      item.addEventListener('click', () => {
        menuToggle.classList.remove('open');
        mobileMenu.classList.remove('open');
      });
    });
  }
</script>
